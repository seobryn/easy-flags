---
import CheckoutButton from "@/components/react/CheckoutButton";
import { StripeService } from "@/application/services/StripeService";

interface BillingPlan {
  name: string;
  price: number;
  features: string[];
  recommended?: boolean;
  priceId?: string;
  description?: string;
}

let plans: BillingPlan[] = [];
let error: string | null = null;

try {
  // Call StripeService directly - no HTTP roundtrip needed
  const prices = await StripeService.getPrices();

  if (prices && prices.length > 0) {
    // Convert Stripe prices to billing plans
    const stripePlans: BillingPlan[] = prices.map((price) => ({
      name: price.product?.name || "Plan",
      price: Math.ceil((price.unit_amount || 0) / 100),
      features: [],
      priceId: price.id,
      description: price.product?.description || undefined,
      recommended: price.product?.name === "Basic",
    }));

    // Sort plans in order: Lab, Basic, Pro
    const planOrder = ["Lab", "Basic", "Pro"];
    stripePlans.sort((a, b) => {
      const indexA = planOrder.indexOf(a.name);
      const indexB = planOrder.indexOf(b.name);
      return (
        (indexA === -1 ? planOrder.length : indexA) -
        (indexB === -1 ? planOrder.length : indexB)
      );
    });

    plans = stripePlans;
  } else {
    error = "No pricing plans available";
  }
} catch (err) {
  console.error("Error fetching pricing plans:", err);
  error = "An error occurred while loading pricing plans";
}
---

<div class="space-y-8">
  {
    error && (
      <div class="bg-red-500/10 border border-red-500/30 text-red-400 px-4 py-3 rounded-lg">
        {error}
      </div>
    )
  }

  {
    plans.length === 0 && !error ? (
      <div class="text-center py-12">
        <p class="text-slate-400">Loading pricing plans...</p>
      </div>
    ) : error || plans.length === 0 ? (
      <div class="text-center py-12">
        <p class="text-slate-400">
          {error || "No pricing plans available at this time"}
        </p>
        <p class="text-slate-500 text-sm mt-2">
          Please check back later or contact support
        </p>
      </div>
    ) : (
      <>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {plans.map((plan) => (
            <div
              class={`border rounded-xl p-8 transition ${
                plan.recommended
                  ? "border-cyan-500/80 bg-gradient-to-b from-cyan-500/10 to-slate-800/50 ring-2 ring-cyan-500/30 scale-105"
                  : "border-slate-700 bg-slate-800/50 hover:border-cyan-500/30"
              }`}
            >
              {plan.recommended && (
                <div class="mb-4 text-sm font-semibold text-cyan-400 bg-cyan-500/10 w-fit px-3 py-1 rounded-full">
                  Recommended
                </div>
              )}

              <h3 class="text-2xl font-bold text-cyan-300 mb-2">{plan.name}</h3>

              {plan.description && (
                <p class="text-slate-400 text-sm mb-4">{plan.description}</p>
              )}

              <div class="flex items-baseline gap-1 mb-6">
                <span class="text-4xl font-bold text-white">${plan.price}</span>
                <span class="text-slate-400">/month</span>
              </div>

              <CheckoutButton client:load plan={plan} />

              <div class="space-y-3">
                {plan.features.map((feature) => (
                  <div class="flex gap-2 items-start">
                    <svg
                      class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    <span class="text-slate-300 text-sm">{feature}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>

        <div class="card text-center">
          <h3 class="text-xl font-bold text-cyan-300 mb-2">Custom Plan</h3>
          <p class="text-slate-400 mb-4">
            Need something different? Contact our sales team for a custom plan
            tailored to your needs.
          </p>
          <a
            href="/contact"
            class="text-cyan-400 hover:text-cyan-300 transition"
          >
            Get in touch →
          </a>
        </div>
      </>
    )
  }
</div>
