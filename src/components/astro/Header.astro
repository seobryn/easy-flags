---
import { getUserFromContext } from "@/utils/auth";
import { isSuperUser } from "@/utils/permissions";
import HeaderDropdown from "@/components/react/shared/HeaderDropdown";
import LanguageSelector from "@/components/react/shared/LanguageSelector";
import { getTranslator, getLocale, getLocalizedPath } from "@/infrastructure/i18n/astro";

const lang = getLocale(Astro.request);
const { t } = getTranslator(Astro.request);
const user = getUserFromContext(Astro);
// Get current path safely - for prerendered pages, this will be undefined
let currentPath = "";
try {
  const url = new URL(Astro.request.url);
  currentPath = url.pathname + url.search;
} catch (e) {
  // In prerendered context, Astro.request.url won't be available
  currentPath = "";
}

const isActive = (path: string) => {
  if (!currentPath) return false; // Don't highlight links in prerendered pages
  // We need to compare against the localized path
  const localizedPath = getLocalizedPath(path, lang);
  return currentPath.startsWith(localizedPath);
};

const navItems = {
  pricing: {
    href: getLocalizedPath("/billing", lang),
    label: t('navigation.pricing') || "Pricing",
    showFor: !user,
  },
  spaces: {
    href: getLocalizedPath("/spaces", lang),
    label: t('navigation.spaces') || "Spaces",
    showFor: !!user,
  },
  metrics: {
    href: getLocalizedPath("/metrics", lang),
    label: t('navigation.metrics') || "Metrics",
    showFor: !!user,
  },
  docs: {
    href: getLocalizedPath("/docs", lang),
    label: t('navigation.docs') || "Docs",
    showFor: true,
  },
  apiReference: {
    href: getLocalizedPath("/api-reference", lang),
    label: t('navigation.apiReference') || "API Reference",
    showFor: true,
  },
  login: {
    href: getLocalizedPath("/login", lang),
    label: t('auth.login') || "Login",
    showFor: !user,
  },
};

const getNavLinkClass = (href: string) => {
  const isCurrentPath = isActive(href);
  if (user) {
    return `transition ${
      isCurrentPath
        ? "text-cyan-300 font-semibold"
        : "text-slate-300 hover:text-cyan-400"
    }`;
  } else {
    return `transition ${
      isCurrentPath
        ? "text-cyan-300 font-semibold"
        : "text-cyan-100 hover:text-cyan-300"
    }`;
  }
};
---

<header id="main-header" class="sticky top-0 z-50 w-full border-b border-white/5 bg-[#06080f]/70 backdrop-blur-2xl transition-all duration-500">
  <nav class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 h-24 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <a href={getLocalizedPath("/", lang)} class="flex items-center gap-4 group">
        <div class="relative">
          <div class="absolute inset-0 bg-cyan-500/20 blur-xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <img src="/logo.svg" alt="Easy Flags" class="w-12 h-12 relative z-10 transition-all duration-500 group-hover:scale-110 group-hover:rotate-3 shadow-2xl shadow-cyan-500/20 rounded-xl border border-white/10" />
        </div>
        <span class="text-2xl font-black tracking-tight bg-linear-to-r from-white via-white to-slate-400 bg-clip-text text-transparent font-display drop-shadow-sm">
          Easy Flags
        </span>
      </a>
    </div>

    <div class="hidden md:flex gap-12 items-center">
      <div class="flex items-center gap-10">
        {
          navItems.pricing.showFor && (
            <a
              href={navItems.pricing.href}
              class={`text-[10px] font-black uppercase tracking-[0.25em] transition-all duration-300 hover:text-cyan-400 ${isActive(navItems.pricing.href) ? 'text-cyan-400 drop-shadow-[0_0_8px_rgba(6,182,212,0.4)]' : 'text-slate-400'}`}
            >
              {navItems.pricing.label}
            </a>
          )
        }

        {
          navItems.spaces.showFor && (
            <a
              href={navItems.spaces.href}
              class={`text-[10px] font-black uppercase tracking-[0.25em] transition-all duration-300 hover:text-cyan-400 ${isActive(navItems.spaces.href) ? 'text-cyan-400 drop-shadow-[0_0_8px_rgba(6,182,212,0.4)]' : 'text-slate-400'}`}
            >
              {navItems.spaces.label}
            </a>
          )
        }

        {
          navItems.metrics.showFor && (
            <a
              href={navItems.metrics.href}
              class={`text-[10px] font-black uppercase tracking-[0.25em] transition-all duration-300 hover:text-cyan-400 ${isActive(navItems.metrics.href) ? 'text-cyan-400 drop-shadow-[0_0_8px_rgba(6,182,212,0.4)]' : 'text-slate-400'}`}
            >
              {navItems.metrics.label}
            </a>
          )
        }


        <a
          href={navItems.docs.href}
          class={`text-[10px] font-black uppercase tracking-[0.25em] transition-all duration-300 hover:text-cyan-400 ${isActive(navItems.docs.href) ? 'text-cyan-400 drop-shadow-[0_0_8px_rgba(6,182,212,0.4)]' : 'text-slate-400'}`}
        >
          {navItems.docs.label}
        </a>

        <a
          href={navItems.apiReference.href}
          class={`text-[10px] font-black uppercase tracking-[0.25em] transition-all duration-300 hover:text-cyan-400 ${isActive(navItems.apiReference.href) ? 'text-cyan-400 drop-shadow-[0_0_8px_rgba(6,182,212,0.4)]' : 'text-slate-400'}`}
        >
          {navItems.apiReference.label}
        </a>
      </div>

      <div class="h-8 w-px bg-white/5 mx-2"></div>

      <div class="flex items-center gap-6">
        {
          user ? (
            <div class="flex items-center gap-8">
              <LanguageSelector 
                client:load 
                currentLang={lang} 
                currentPath={currentPath}
              />
              <div class="h-8 w-px bg-white/5"></div>
              <HeaderDropdown
                client:load
                username={user.username}
                isSuperUser={isSuperUser(user)}
                initialLocale={lang}
              />
            </div>
          ) : (
            <div class="flex items-center gap-8">
              <LanguageSelector 
                client:load 
                currentLang={lang} 
                currentPath={currentPath}
              />
              <div class="h-8 w-px bg-white/5"></div>
              <a
                href={navItems.login.href}
                class="text-[10px] font-black uppercase tracking-[0.25em] text-white hover:text-cyan-400 transition-all px-2"
              >
                {navItems.login.label}
              </a>
              <a href={getLocalizedPath("/create-account", lang)} class="btn-primary text-[10px] px-8! py-3.5! uppercase tracking-widest shadow-2xl shadow-cyan-500/20">
                {t('auth.getStarted') || "Get Started"}
              </a>
            </div>
          )
        }
      </div>
    </div>

    <!-- Mobile Menu Button -->
    <div class="flex items-center md:hidden">
      <button 
        id="mobile-menu-button"
        class="relative z-10000 p-2 text-slate-400 hover:text-white transition-colors focus:outline-none"
        aria-label="Toggle Menu"
      >
        <div class="w-7 h-5 flex flex-col justify-between items-end">
          <span id="bar-1" class="w-7 h-0.5 bg-white transition-all duration-300"></span>
          <span id="bar-2" class="w-5 h-0.5 bg-white transition-all duration-300"></span>
          <span id="bar-3" class="w-6 h-0.5 bg-white transition-all duration-300"></span>
        </div>
      </button>
    </div>
  </nav>

</header>

<div 
  id="mobile-menu" 
  class="fixed inset-0 bg-[#06080f] z-9999 flex flex-col items-center justify-center opacity-0 pointer-events-none transition-all duration-300 ease-in-out"
  style="background-color: #06080f; opacity: 0; visibility: hidden;"
>
  <!-- Background Glows -->
  <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-cyan-500/10 blur-[120px] rounded-full pointer-events-none"></div>
  <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-blue-600/10 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="flex flex-col items-center gap-10 w-full px-10">
    <div class="flex flex-col items-center gap-6">
      {
        navItems.pricing.showFor && (
          <a 
            href={navItems.pricing.href} 
            class="mobile-nav-link text-3xl font-bold text-white uppercase tracking-[0.3em] hover:text-cyan-400 transition-colors"
          >
            {navItems.pricing.label}
          </a>
        )
      }
      {
        navItems.spaces.showFor && (
          <a 
            href={navItems.spaces.href} 
            class="mobile-nav-link text-3xl font-bold text-white uppercase tracking-[0.3em] hover:text-cyan-400 transition-colors"
          >
            {navItems.spaces.label}
          </a>
        )
      }
      {
        navItems.metrics.showFor && (
          <a 
            href={navItems.metrics.href} 
            class="mobile-nav-link text-3xl font-bold text-white uppercase tracking-[0.3em] hover:text-cyan-400 transition-colors"
          >
            {navItems.metrics.label}
          </a>
        )
      }
      <a 
        href={navItems.docs.href} 
        class="mobile-nav-link text-3xl font-bold text-white uppercase tracking-[0.3em] hover:text-cyan-400 transition-colors"
      >
        {navItems.docs.label}
      </a>
      <a 
        href={navItems.apiReference.href} 
        class="mobile-nav-link text-3xl font-bold text-white uppercase tracking-[0.3em] hover:text-cyan-400 transition-colors"
      >
        {navItems.apiReference.label}
      </a>
    </div>
    
    <div class="w-20 h-px bg-white/10 my-4"></div>
    
    {
      user ? (
        <div class="flex flex-col items-center gap-8 w-full">
          <div class="flex flex-col items-center gap-3">
            <div class="w-16 h-16 rounded-2xl bg-linear-to-br from-cyan-400 to-blue-600 flex items-center justify-center text-white font-bold text-2xl shadow-lg shadow-cyan-500/20">
              {user.username.charAt(0).toUpperCase()}
            </div>
            <span class="text-white text-xl font-medium tracking-tight">{user.username}</span>
          </div>
          
          <!-- Mobile Language Selector -->
          <div class="flex gap-4 p-1.5 bg-white/5 rounded-2xl border border-white/5 w-full max-w-[280px] mt-2">
            {
              [
                { code: "en", flag: "🇺🇸", name: "EN" },
                { code: "es", flag: "🇪🇸", name: "ES" },
                { code: "fr", flag: "🇫🇷", name: "FR" }
              ].map((l) => (
                <a 
                  href={`/api/i18n/set-language?lang=${l.code}&redirect=${encodeURIComponent(currentPath)}`}
                  class={`flex-1 flex items-center justify-center gap-1.5 py-2.5 rounded-xl transition-all duration-300 font-bold text-xs tracking-widest ${
                    lang === l.code 
                      ? "bg-white/10 text-cyan-400 border border-white/10" 
                      : "text-slate-500 border border-transparent hover:text-white"
                  }`}
                >
                  <span class="text-sm">{l.flag}</span>
                  {l.name}
                </a>
              ))
            }
          </div>

          <div class="flex flex-col items-center gap-4 mt-2">
            {isSuperUser(user) && (
              <a href={getLocalizedPath("/admin/db-inspector", lang)} class="px-8 py-3 rounded-full border border-cyan-500/30 bg-cyan-500/5 text-cyan-400 font-bold uppercase tracking-widest text-sm hover:bg-cyan-500 hover:text-white transition-all">
                Inspector
              </a>
            )}
            
            <a href={getLocalizedPath("/billing", lang)} class="text-slate-400 hover:text-white transition-colors uppercase tracking-widest text-xs font-bold">Billing</a>

            <a href={getLocalizedPath("/settings", lang)} class="text-slate-400 hover:text-white transition-colors uppercase tracking-widest text-xs font-bold">Settings</a>
            
            <form action="/api/auth/logout" method="POST">
              <button type="submit" class="text-red-500/60 hover:text-red-500 transition-colors uppercase tracking-widest text-xs font-bold">
                Logout
              </button>
            </form>
          </div>
        </div>
      ) : (
        <div class="flex flex-col items-center gap-6 w-full max-w-xs">
          <!-- Mobile Language Selector for Guests -->
          <div class="flex gap-4 p-1.5 bg-white/5 rounded-2xl border border-white/5 w-full mb-4">
            {
              [
                { code: "en", flag: "🇺🇸", name: "EN" },
                { code: "es", flag: "🇪🇸", name: "ES" },
                { code: "fr", flag: "🇫🇷", name: "FR" }
              ].map((l) => (
                <a 
                  href={`/api/i18n/set-language?lang=${l.code}&redirect=${encodeURIComponent(currentPath)}`}
                  class={`flex-1 flex items-center justify-center gap-1.5 py-2.5 rounded-xl transition-all duration-300 font-bold text-xs tracking-widest ${
                    lang === l.code 
                      ? "bg-white/10 text-cyan-400 border border-white/10" 
                      : "text-slate-500 border border-transparent hover:text-white"
                  }`}
                >
                  <span class="text-sm">{l.flag}</span>
                  {l.name}
                </a>
              ))
            }
          </div>

          <a href={navItems.login.href} class="text-xl font-bold text-white uppercase tracking-widest hover:text-cyan-400 transition-colors">
            {navItems.login.label}
          </a>
          <a href={getLocalizedPath("/create-account", lang)} class="w-full btn-primary text-center py-5 rounded-2xl shadow-none">
            {t('auth.getStarted') || "Get Started"}
          </a>
        </div>
      )
    }
  </div>
</div>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar-1');
  const bar2 = document.getElementById('bar-2');
  const bar3 = document.getElementById('bar-3');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  const mainHeader = document.getElementById('main-header');

  if (mobileMenuButton && mobileMenu && bar1 && bar2 && bar3 && mainHeader) {
    const toggleMenu = () => {
      const isOpen = !mobileMenu.classList.contains('opacity-0');
      
      if (!isOpen) {
        // Open
        mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
        mobileMenu.classList.add('opacity-100');
        mobileMenu.style.opacity = '1';
        mobileMenu.style.visibility = 'visible';
        mainHeader.style.zIndex = '10000';
        mainHeader.style.backgroundColor = 'transparent';
        mainHeader.style.borderBottom = 'none';
        bar1.style.transform = 'translateY(9px) rotate(45deg)';
        bar2.style.opacity = '0';
        bar3.style.transform = 'translateY(-9px) rotate(-45deg)';
        document.body.style.overflow = 'hidden';
      } else {
        // Close
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100');
        mobileMenu.style.opacity = '0';
        mobileMenu.style.visibility = 'hidden';
        mainHeader.style.zIndex = '50';
        mainHeader.style.backgroundColor = ''; // Reset to class default
        mainHeader.style.borderBottom = '';
        bar1.style.transform = 'none';
        bar2.style.opacity = '1';
        bar3.style.transform = 'none';
        document.body.style.overflow = 'auto';
      }
    };

    mobileMenuButton.addEventListener('click', toggleMenu);

    // Close menu when clicking links
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100');
        mobileMenu.style.opacity = '0';
        mobileMenu.style.visibility = 'hidden';
        mainHeader.style.zIndex = '50';
        mainHeader.style.backgroundColor = '';
        mainHeader.style.borderBottom = '';
        bar1.style.transform = 'none';
        bar2.style.opacity = '1';
        bar3.style.transform = 'none';
        document.body.style.overflow = 'auto';
      });
    });
  }
</script>
