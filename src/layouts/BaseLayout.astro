---
import "@/styles/globals.css";
import Header from "@/components/astro/Header.astro";
import Modals from "@/components/react/shared/Modals";
import { I18nProvider } from "@/infrastructure/i18n/context";
import { getLocale } from "@/infrastructure/i18n/astro";

interface Props {
  title?: string;
  description?: string;
  includeHeader?: boolean;
  fullWidth?: boolean;
  children?: any;
}

const {
  title = "Easy Flags",
  description = "Feature flag management system",
  includeHeader = true,
  fullWidth = false,
} = Astro.props;

const locale = getLocale(Astro.request);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class={`bg-[#06080f] text-slate-100 selection:bg-cyan-500/30 min-h-screen`}>
    <I18nProvider client:load initialLocale={locale}>
      <div class="root flex flex-col min-h-screen">
        {includeHeader && <Header />}
        {
          fullWidth ? (
            <slot />
          ) : (
            <main class="flex-1 max-w-7xl mx-auto px-4 w-full">
              <slot />
            </main>
          )
        }
        <Modals client:load />
      </div>
    </I18nProvider>
  </body>
</html>

<script>
  // Client-side interactivity can be added here
  console.log("Layout loaded");
</script>
