---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import { getTranslator } from "@/infrastructure/i18n/astro";

const { t } = getTranslator(Astro.request);
---

<BaseLayout seoKey="privacy" includeHeader={true}>
  <article class="max-w-4xl mx-auto py-12">
    <h1 class="text-4xl font-bold text-gradient mb-6">{t('privacy.title')}</h1>

    <div class="card space-y-6 text-slate-300 prose-invert">
      <section>
        <h2 class="text-2xl font-bold text-cyan-300 mb-3">{t('privacy.introTitle')}</h2>
        <p class="text-slate-400">
          {t('privacy.introDesc')}
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-cyan-300 mb-3">
          {t('privacy.collectTitle')}
        </h2>
        <p class="text-slate-400 mb-4">
          {t('privacy.collectDesc')}
        </p>
        <ul class="list-disc list-inside text-slate-400 space-y-2 ml-4">
          <li>
            {t('privacy.personalData')}
          </li>
          <li>
            {t('privacy.featureData')}
          </li>
          <li>
            {t('privacy.usageData')}
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-cyan-300 mb-3">
          {t('privacy.useTitle')}
        </h2>
        <p class="text-slate-400 mb-4">{t('privacy.useDesc')}</p>
        <ul class="list-disc list-inside text-slate-400 space-y-2 ml-4">
          <li>{t('privacy.useItem1')}</li>
          <li>{t('privacy.useItem2')}</li>
          <li>{t('privacy.useItem3')}</li>
          <li>{t('privacy.useItem4')}</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-cyan-300 mb-3">{t('privacy.securityTitle')}</h2>
        <p class="text-slate-400">
          {t('privacy.securityDesc')}
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-cyan-300 mb-3">{t('privacy.contactTitle')}</h2>
        <p class="text-slate-400">
          {t('privacy.contactDesc')}
        </p>
      </section>
    </div>
  </article>
</BaseLayout>
