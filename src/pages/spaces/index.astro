---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { requireAuth, getLoginUrl } from "@/utils/auth-redirect";
import SpacesDashboard from "@/components/react/SpacesDashboard";

export const prerender = false;

// Require authentication (includes redirect parameter)
if (!requireAuth(Astro)) {
  return Astro.redirect(getLoginUrl(Astro));
}
---

<BaseLayout title="Spaces - Feature Flags" includeHeader={true}>
  <SpacesDashboard client:load />
</BaseLayout>
