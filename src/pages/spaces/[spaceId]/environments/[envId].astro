---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { requireAuth } from "@/utils/auth-redirect";
import {
  validateNestedResource,
  checkResourceExists,
} from "@/utils/resource-validation";
import EnvironmentDetailView from "@/components/react/EnvironmentDetailView";
import { SpaceService, EnvironmentService } from "@application/services";

export const prerender = false;

// Require authentication (includes redirect parameter)
requireAuth(Astro);

const { spaceId, envId } = Astro.params;
const spaceIdNum = parseInt(spaceId as string);
const envIdNum = parseInt(envId as string);

// Verify space exists first
const spaceService = new SpaceService();
const space = await spaceService.getSpace(spaceIdNum);
checkResourceExists(space, Astro, "Space");

// Verify environment exists and belongs to the space
const environmentService = new EnvironmentService();
const environment = await environmentService.getEnvironment(envIdNum);
validateNestedResource(
  environment,
  "space_id",
  spaceIdNum,
  Astro,
  "Environment",
);

const title = `${environment.name} - Configuration`;
---

<BaseLayout title={title} includeHeader={true}>
  <EnvironmentDetailView
    client:load
    spaceId={spaceId}
    envId={envId}
    envName={environment.name}
    envDescription={environment.description}
  />
</BaseLayout>
