---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EnvironmentDetailView from "@/components/react/EnvironmentDetailView";
import { EnvironmentService } from "@application/services";

export const prerender = false;

const { spaceId, envId } = Astro.params;

let environment = null;
let errorMessage = "";

try {
  if (envId) {
    const environmentService = new EnvironmentService();
    environment = await environmentService.getEnvironment(parseInt(envId));

    if (!environment) {
      errorMessage = "Environment not found";
    }
  }
} catch (error) {
  errorMessage = "Failed to load environment";
  console.error("Error fetching environment:", error);
}

const title = environment
  ? `${environment.name} - Configuration`
  : "Environment - Configuration";
---

<BaseLayout title={title} includeHeader={true}>
  {
    errorMessage ? (
      <div class="max-w-4xl mx-auto py-12 px-4">
        <div class="card text-center py-12">
          <p class="text-red-400 mb-4">{errorMessage}</p>
          <a
            href={`/spaces/${spaceId}/environments`}
            class="text-cyan-400 hover:text-cyan-300"
          >
            Back to Environments
          </a>
        </div>
      </div>
    ) : environment ? (
      <EnvironmentDetailView
        client:load
        spaceId={spaceId}
        envId={envId}
        envName={environment.name}
        envDescription={environment.description}
      />
    ) : (
      <div class="max-w-4xl mx-auto py-12 px-4">
        <div class="card text-center py-12">
          <p class="text-slate-400 mb-4">Loading environment...</p>
        </div>
      </div>
    )
  }
</BaseLayout>
