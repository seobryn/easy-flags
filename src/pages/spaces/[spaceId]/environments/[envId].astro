---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { requireAuth, getLoginUrl } from "@/utils/auth-redirect";
import {
  validateNestedResource,
  checkResourceExists,
} from "@/utils/resource-validation";
import EnvironmentDetailView from "@/components/react/environments/EnvironmentDetailView";
import { SpaceService, EnvironmentService } from "@application/services";

export const prerender = false;

// Require authentication (includes redirect parameter)
if (!requireAuth(Astro)) {
  return Astro.redirect(getLoginUrl(Astro));
}

const { spaceId: spaceSlug, envId: envSlug } = Astro.params;

// Verify space exists first
const spaceService = new SpaceService();
const space = (await spaceService.getSpaceBySlug(spaceSlug as string))!;
if (!checkResourceExists(space, Astro, "Space")) {
  return Astro.redirect("/404");
}

// Verify environment exists and belongs to the space (lookup by slug)
const environmentService = new EnvironmentService();
const env = (await environmentService.getEnvironmentBySlug(
  space.id,
  envSlug as string,
))!;
if (!env) {
  return Astro.redirect("/404");
}

const title = `${env.name} - Configuration`;
---

<BaseLayout title={title} includeHeader={true}>
  <EnvironmentDetailView
    client:load
    spaceId={space.slug}
    envId={env.slug}
    envName={env.name}
    envDescription={env.description}
    createdAt={env.created_at}
  />
</BaseLayout>
