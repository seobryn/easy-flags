---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { requireAuth } from "@/utils/auth-redirect";
import {
  validateNestedResource,
  checkResourceExists,
} from "@/utils/resource-validation";
import AdvancedConfigurationView from "@/components/react/AdvancedConfigurationView";
import { SpaceService, FeatureService } from "@application/services";

export const prerender = false;

// Require authentication (includes redirect parameter)
requireAuth(Astro);

const { spaceId, featureId } = Astro.params;
const spaceIdNum = parseInt(spaceId as string);
const featureIdNum = parseInt(featureId as string);

// Verify space exists first
const spaceService = new SpaceService();
const space = await spaceService.getSpace(spaceIdNum);
checkResourceExists(space, Astro, "Space");

// Verify feature exists and belongs to the space
const featureService = new FeatureService();
const feature = await featureService.getFeature(featureIdNum);
validateNestedResource(feature, "space_id", spaceIdNum, Astro, "Feature");

const title = `${feature.name} - Advanced Configuration`;
---

<BaseLayout title={title} includeHeader={true}>
  <AdvancedConfigurationView
    client:load
    spaceId={spaceId}
    featureId={featureId}
    featureName={feature.name}
    featureKey={feature.key}
    featureType={feature.type}
  />
</BaseLayout>
