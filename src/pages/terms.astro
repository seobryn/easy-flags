---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import { getTranslator } from "@/infrastructure/i18n/astro";

const { t } = getTranslator(Astro.request);
---

<BaseLayout seoKey="terms" includeHeader={true}>
  <article class="max-w-4xl mx-auto py-12">
    <h1 class="text-4xl font-bold text-gradient mb-6">{t('terms.title')}</h1>

    <div class="card space-y-6 text-slate-300">
      <section>
        <h2 class="text-2xl font-bold text-cyan-300 mb-3">
          {t('terms.acceptanceTitle')}
        </h2>
        <p class="text-slate-400">
          {t('terms.acceptanceDesc')}
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-cyan-300 mb-3">{t('terms.licenseTitle')}</h2>
        <p class="text-slate-400 mb-4">
          {t('terms.licenseDesc')}
        </p>
        <ul class="list-disc list-inside text-slate-400 space-y-2 ml-4">
          <li>{t('terms.licenseItem1')}</li>
          <li>{t('terms.licenseItem2')}</li>
          <li>{t('terms.licenseItem3')}</li>
          <li>{t('terms.licenseItem4')}</li>
          <li>
            {t('terms.licenseItem5')}
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-cyan-300 mb-3">{t('terms.disclaimerTitle')}</h2>
        <p class="text-slate-400">
          {t('terms.disclaimerDesc')}
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-cyan-300 mb-3">{t('terms.limitationsTitle')}</h2>
        <p class="text-slate-400">
          {t('terms.limitationsDesc')}
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-cyan-300 mb-3">
          {t('terms.accuracyTitle')}
        </h2>
        <p class="text-slate-400">
          {t('terms.accuracyDesc')}
        </p>
      </section>
    </div>
  </article>
</BaseLayout>
