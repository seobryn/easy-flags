---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Roles" includeHeader={true}>
  <div class="max-w-4xl mx-auto py-12">
    <h1 class="text-4xl font-bold text-gradient mb-6">Roles Management</h1>

    <div class="card">
      <p class="text-slate-400 mb-6">
        Manage roles and permissions for your organization. Assign roles to team
        members to control their access levels.
      </p>

      <div class="bg-slate-700/50 border border-slate-600 rounded-lg p-4 text-center text-slate-400">
        <p>Role management interface coming soon</p>
      </div>
    </div>
  </div>
</BaseLayout>
