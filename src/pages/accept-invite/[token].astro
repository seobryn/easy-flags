---
import AcceptInvitation from "@/components/react/settings/AcceptInvitation";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Accept Invitation">
  <div class="min-h-screen bg-slate-950 text-white flex flex-col items-center justify-center p-4">
    <div class="max-w-md w-full">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold tracking-tight text-white">
          Accept Your Invitation
        </h1>
        <p class="text-slate-400 text-lg leading-relaxed mt-2">
          Join us and start managing your feature flags
        </p>
      </div>

      <AcceptInvitation client:load />
    </div>
  </div>
</BaseLayout>