---
// src/pages/dev/db-inspector.astro
// Development-only database inspection page
import DatabaseInspector from "@/components/react/DatabaseInspector";
import { requireAuth, getLoginUrl } from "@/utils/auth-redirect";
import { isGlobalAdmin, ROLES } from "@/utils/permissions";
import { getUserFromContext } from "@/utils/auth";

// Require authentication
console.log("[db-inspector] Checking auth...");
if (!requireAuth(Astro)) {
  console.log("[db-inspector] User not authenticated, redirecting to login");
  return Astro.redirect(getLoginUrl(Astro));
}

// Check if user is a global admin
const user = getUserFromContext(Astro);
console.log("[db-inspector] User object:", user);
console.log("[db-inspector] User role_id:", user?.role_id);
console.log("[db-inspector] ROLES.ADMIN value:", ROLES.ADMIN);
console.log("[db-inspector] Is global admin?", isGlobalAdmin(user));

if (!user || !isGlobalAdmin(user)) {
  console.log(
    "[db-inspector] User is not a global admin. Redirecting to home.",
  );
  return Astro.redirect("/");
}

console.log("[db-inspector] Access granted to admin user:", user.username);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Database Inspector - Development</title>
    <meta name="description" content="Development database inspection tool" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <div class="min-h-screen bg-slate-900">
      <DatabaseInspector client:load />
    </div>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    color-scheme: dark;
  }

  body {
    font-family: "Inter", sans-serif;
    @apply antialiased bg-slate-900;
    font-feature-settings:
      "rlig" 1,
      "calt" 1;
  }

  @tailwind base;
  @tailwind components;
  @tailwind utilities;
</style>
