---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { redirectIfAuthenticated } from "@/utils/auth-redirect";
import LoginForm from "@/components/react/LoginForm";

export const prerender = false;

// Redirect authenticated users to spaces
redirectIfAuthenticated(Astro);

// Get redirect URL from query params (where user was trying to go)
const redirectUrl = Astro.url.searchParams.get("redirect") || "/spaces";
---

<BaseLayout title="Login - Feature Flags" includeHeader={false}>
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-gradient mb-2">Easy Flags</h1>
        <p class="text-slate-400">Sign in to your account</p>
      </div>
      <LoginForm client:load redirectUrl={redirectUrl} />
    </div>
  </div>
</BaseLayout>
