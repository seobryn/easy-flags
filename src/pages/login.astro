---
import BaseLayout from "@/layouts/BaseLayout.astro";
import LoginForm from "@/components/react/LoginForm";
---

<BaseLayout title="Login - Feature Flags" includeHeader={false}>
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-gradient mb-2">Easy Flags</h1>
        <p class="text-slate-400">Sign in to your account</p>
      </div>
      <LoginForm client:load />
    </div>
  </div>
</BaseLayout>
