---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { redirectIfAuthenticated } from "@/utils/auth-redirect";
import LoginForm from "@/components/react/auth/LoginForm";
import { getTranslator } from "@/infrastructure/i18n/astro";

const { t } = getTranslator(Astro.request);

export const prerender = false;

// Redirect authenticated users to spaces
if (redirectIfAuthenticated(Astro)) {
  return Astro.redirect("/spaces");
}

// Get redirect URL from query params (where user was trying to go)
const redirectUrl = Astro.url.searchParams.get("redirect") || "/spaces";
---

<BaseLayout title={`${t('auth.login')} - Easy Flags`} includeHeader={false}>
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center mb-6">
          <img src="/logo.svg" alt="Easy Flags" class="w-16 h-16 shadow-2xl shadow-cyan-500/20 rounded-2xl animate-fade-in" />
        </div>
        <h1 class="text-4xl font-bold text-gradient mb-2">Easy Flags</h1>
        <p class="text-slate-400">{t('auth.signInToAccount')}</p>
      </div>
      <LoginForm client:load redirectUrl={redirectUrl} />
    </div>
  </div>
</BaseLayout>
