---
import BaseLayout from "@/layouts/BaseLayout.astro";
import MetricsMonitor from "@/components/react/analytics/MetricsMonitor";
import { requireAuth, getLoginUrl } from "@/utils/auth-redirect";
import { getUserFromContext } from "@/utils/auth";

export const prerender = false;

// Check authentication
if (!requireAuth(Astro)) {
    return Astro.redirect(getLoginUrl(Astro));
}

// Get user
const user = getUserFromContext(Astro);
if (!user) {
    return Astro.redirect("/login");
}
---

<BaseLayout title="Metrics - Easy Flags" includeHeader={true}>
    <MetricsMonitor client:load userId={String(user.id)} />
</BaseLayout>
