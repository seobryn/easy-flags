---
import BaseLayout from "@/layouts/BaseLayout.astro";
import MetricsMonitor from "@/components/react/analytics/MetricsMonitor";
import { requireAuth, getLoginUrl } from "@/utils/auth-redirect";
import { getUserFromContext } from "@/utils/auth";
import { getTranslator, getLocale } from "@/infrastructure/i18n/astro";

const { t } = getTranslator(Astro.request);
const initialLocale = getLocale(Astro.request);

export const prerender = false;

// Check authentication
if (!requireAuth(Astro)) {
    return Astro.redirect(getLoginUrl(Astro));
}

// Get user
const user = getUserFromContext(Astro);
if (!user) {
    return Astro.redirect("/login");
}
---

<BaseLayout seoKey="metrics" includeHeader={true}>
    <MetricsMonitor client:load userId={String(user.id)} initialLocale={initialLocale} />
</BaseLayout>
