---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import { getTranslator } from "@/infrastructure/i18n/astro";
import { Icon } from "@/components/react/shared/Icon";

const { t } = getTranslator(Astro.request);
---

<BaseLayout seoKey="forbidden" includeHeader={true}>
  <div class="min-h-[80vh] flex items-center justify-center px-4 relative overflow-hidden">
    {/* Decorative Elements */}
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-red-500/5 blur-[120px] rounded-full animate-pulse"></div>
    
    <div class="max-w-2xl w-full text-center relative z-10 animate-in fade-in slide-in-from-bottom-12 duration-1000">
      <div class="inline-flex items-center justify-center w-24 h-24 rounded-[32px] bg-red-500/10 border border-red-500/20 text-red-500 mb-10 shadow-2xl shadow-red-500/20">
        <Icon client:load name="Shield" size={48} />
      </div>
      
      <div class="relative mb-8">
        <div class="text-[120px] md:text-[180px] font-black text-white/5 leading-none select-none">403</div>
        <div class="absolute inset-0 flex items-center justify-center">
          <h1 class="text-4xl md:text-5xl font-black text-white tracking-tighter uppercase whitespace-nowrap">
             {t('errors.403.title').split(' ')[0]} <span class="bg-linear-to-r from-red-500 to-amber-500 bg-clip-text text-transparent">{t('errors.403.title').split(' ').slice(1).join(' ')}</span>
          </h1>
        </div>
      </div>
      
      <p class="text-slate-400 text-lg md:text-xl font-medium mb-12 max-w-lg mx-auto leading-relaxed">
        {t('errors.403.description')}
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="/" class="w-full sm:w-auto btn-primary px-10! py-5! flex items-center justify-center gap-3 shadow-2xl shadow-cyan-500/20 transition-all hover:scale-105 active:scale-95">
          <Icon client:load name="ArrowRight" size={20} />
          <span class="font-black text-xs uppercase tracking-widest">{t('errors.403.returnHome')}</span>
        </a>
        <button onclick="window.history.back()" class="w-full sm:w-auto px-10 py-5 rounded-2xl bg-white/5 border border-white/10 text-slate-400 text-xs font-black uppercase tracking-widest hover:bg-white/10 hover:text-white transition-all">
          {t('errors.403.abortSession')}
        </button>
      </div>
      
      <div class="mt-20 pt-8 border-t border-white/5">
         <p class="text-[9px] font-black text-slate-700 uppercase tracking-[0.5em]">{t('errors.403.securityVoidFooter')}</p>
      </div>
    </div>
  </div>
</BaseLayout>
