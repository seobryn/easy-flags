---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { redirectIfAuthenticated } from "@/utils/auth-redirect";
import RegisterForm from "@/components/react/auth/RegisterForm";
import { getTranslator, getLocalizedPath } from "@/infrastructure/i18n/astro";

const { t, lang } = getTranslator(Astro.request);

export const prerender = false;

// Redirect authenticated users to spaces
if (redirectIfAuthenticated(Astro)) {
  return Astro.redirect(getLocalizedPath("/spaces", lang as any));
}
---

<BaseLayout seoKey="createAccount" includeHeader={false}>
  <div class="min-h-screen w-full relative overflow-x-hidden flex items-center justify-center py-20">
    {/* Background Decorative Elements - Bleeding across screen */}
    <div class="fixed top-1/4 -right-20 w-[600px] h-[600px] bg-purple-500/10 blur-[150px] rounded-full animate-pulse pointer-events-none"></div>
    <div class="fixed bottom-1/4 -left-20 w-[600px] h-[600px] bg-cyan-500/10 blur-[150px] rounded-full animate-pulse delay-1000 pointer-events-none"></div>

    <div class="w-full max-w-xl px-4 relative z-10 animate-in fade-in slide-in-from-bottom-8 duration-1000">
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center mb-8">
           <div class="relative group">
            <div class="absolute inset-0 bg-purple-500/30 blur-2xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            <img src="/logo.svg" alt="Easy Flags" class="w-16 h-16 relative z-10 shadow-2xl rounded-2xl group-hover:scale-110 transition-transform duration-700" />
           </div>
        </div>
        <h1 class="text-4xl font-black text-white mb-4 tracking-tighter uppercase whitespace-nowrap">
          {t('auth.joinNexus').split(' ').slice(0, -1).join(' ')} <span class="bg-linear-to-r from-purple-400 to-cyan-400 bg-clip-text text-transparent">{t('auth.joinNexus').split(' ').slice(-1)}</span>
        </h1>
        <p class="text-slate-400 text-lg font-medium tracking-tight">
          {t('auth.createYourAccount')}
        </p>
      </div>

      <RegisterForm client:load />

      <div class="mt-12 text-center">
        <p class="text-[10px] font-black text-slate-700 uppercase tracking-[0.4em]">
          {t('auth.secureNodesFooter')}
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
