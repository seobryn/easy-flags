---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getTranslator } from "@/infrastructure/i18n/astro";
import ResetPasswordForm from "@/components/react/auth/ResetPasswordForm";

const { t, lang, getLocalizedPath } = getTranslator(Astro.request);

// Get token from URL params
const { token } = Astro.params;

// Redirect to forgot password page if token is missing
if (!token) {
  return Astro.redirect(getLocalizedPath("/forgot-password", lang as any));
}

// Get redirect URL from query params (where user was trying to go)
const redirectUrl = Astro.url.searchParams.get("redirect") || getLocalizedPath("/spaces", lang as any);
---
<BaseLayout seoKey="resetPassword" includeHeader={false}>
  <div class="min-h-screen w-full relative overflow-x-hidden flex items-center justify-center py-20">
    {/* Background Decorative Elements */}
    <div class="fixed top-1/4 -left-20 w-[500px] h-[500px] bg-cyan-500/10 blur-[120px] rounded-full animate-pulse pointer-events-none"></div>
    <div class="fixed bottom-1/4 -right-20 w-[500px] h-[500px] bg-purple-500/10 blur-[120px] rounded-full animate-pulse delay-1000 pointer-events-none"></div>

    <div class="w-full max-w-md px-4 relative z-10 animate-in fade-in zoom-in duration-1000">
      <div class="text-center mb-12">
        <div class="inline-flex items-center justify-center mb-8 group">
          <div class="relative">
            <div class="absolute inset-0 bg-cyan-500/40 blur-2xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            <img src="/logo.svg" alt="Easy Flags" class="w-20 h-20 relative z-20 shadow-2xl rounded-[24px] transition-transform duration-700 group-hover:scale-110 group-hover:rotate-6" />
          </div>
        </div>
        <h1 class="text-4xl font-black text-white mb-4 tracking-tighter">
          EASY<span class="bg-linear-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">FLAGS</span>
        </h1>
        <div class="inline-block">
            <p class="text-slate-400 text-lg font-medium tracking-tight bg-white/5 border border-white/10 px-6 py-2 rounded-full">
            {t('auth.resetPassword')}
            </p>
        </div>
      </div>
      
      <ResetPasswordForm client:load token={token} redirectUrl={redirectUrl} />
      
      <div class="mt-12 text-center">
        <p class="text-[10px] font-black text-slate-600 uppercase tracking-[0.4em]">
          &copy; 2026 ORANGE EMBER STUDIOS
        </p>
      </div>
    </div>
  </div>
</BaseLayout>