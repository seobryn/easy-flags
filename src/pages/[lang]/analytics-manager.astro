---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AnalyticsManagerComponent from "@/components/react/analytics/AnalyticsManager";

import {
  requireAuth,
  getUserFromAstroContext,
  getLoginUrl,
} from "@/utils/auth-redirect";
import { hasFeatureAccess, FEATURES, isGlobalAdmin } from "@/utils/permissions";
import { getTranslator, getLocalizedPath } from "@/infrastructure/i18n/astro";

export const prerender = false;

// Check authentication
if (!requireAuth(Astro)) {
  return Astro.redirect(getLoginUrl(Astro));
}

// Get user and check feature access
const user = getUserFromAstroContext(Astro);
const { t, lang } = getTranslator(Astro.request);

const hasAccess = user && hasFeatureAccess(user, FEATURES.FEATURE_FLAGS);
if (!hasAccess) {
  return Astro.redirect(getLocalizedPath("/forbidden", lang as any));
}

const isAdmin = user && isGlobalAdmin(user);
---

<BaseLayout seoKey="analytics" includeHeader={true}>
  <div
    class="min-h-screen bg-linear-to-br from-slate-900 via-slate-800 to-slate-900"
  >
    <AnalyticsManagerComponent
      client:load
      userId={String(user.id)}
      isAdmin={isAdmin}
    />
  </div>
</BaseLayout>
