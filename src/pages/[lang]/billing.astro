---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import BillingPlans from "@/components/astro/BillingPlans.astro";
import { getUserFromContext } from "@/utils/auth";
import { getTranslator } from "@/infrastructure/i18n/astro";
import { Icon } from "@/components/react/shared/Icon";

const { t } = getTranslator(Astro.request);

// Allow logged-in users to see plans
const user = getUserFromContext(Astro);
---

<BaseLayout seoKey="pricing" includeHeader={true}>
  <div class="relative min-h-screen py-20 overflow-x-hidden">
    {/* Background Decorative elements - following Nebula pattern */}
    <div class="fixed top-20 -left-20 w-[600px] h-[600px] bg-cyan-500/5 blur-[150px] rounded-full pointer-events-none -z-10"></div>
    <div class="fixed bottom-0 -right-20 w-[600px] h-[600px] bg-blue-600/5 blur-[150px] rounded-full pointer-events-none -z-10"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <header class="mb-20 animate-in slide-in-from-top-4 duration-1000">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-[10px] font-black uppercase tracking-widest mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan-500 animate-pulse"></span>
          Scalable Infrastructure
        </div>
        <h1 class="text-5xl md:text-7xl font-black text-white mb-6 tracking-tighter leading-[1.1]">
           {t('billing.title').split(' & ')[0]} <span class="bg-linear-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">& {t('billing.title').split(' & ')[1] || 'Plans'}</span>
        </h1>
        <p class="text-slate-400 text-lg md:text-xl font-medium max-w-2xl leading-relaxed">
          Select the optimal node for your operations. All plans include our core low-latency evaluation engine.
        </p>
      </header>

      <BillingPlans />
      
      <footer class="mt-32 pt-12 border-t border-white/5 text-center flex flex-col items-center gap-8">
         <div class="flex gap-12">
            <div class="flex flex-col items-center gap-2">
               <span class="text-white font-black text-xl">99.99%</span>
               <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Uptime SLA</span>
            </div>
            <div class="w-px h-10 bg-white/5"></div>
            <div class="flex flex-col items-center gap-2">
               <span class="text-white font-black text-xl">&lt;1ms</span>
               <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Global Latency</span>
            </div>
            <div class="w-px h-10 bg-white/5"></div>
            <div class="flex flex-col items-center gap-2">
               <span class="text-white font-black text-xl">256-bit</span>
               <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Encryption</span>
            </div>
         </div>
         <p class="text-[9px] font-black text-slate-700 uppercase tracking-[0.4em]">NODE_STATUS: OPTIMAL &bull; REGION: GLOBAL_EDGE</p>
      </footer>
    </div>
  </div>
</BaseLayout>
