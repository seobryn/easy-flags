---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import { getTranslator } from "@/infrastructure/i18n/astro";
import { Icon } from "@/components/react/shared/Icon";

const { t } = getTranslator(Astro.request);
---

<BaseLayout seoKey="apiReference" includeHeader={true} fullWidth={true}>
  <div class="min-h-screen bg-[#06080f] overflow-x-hidden">
    <!-- Hero Section -->
    <div class="relative py-24 px-8 md:px-16 overflow-hidden border-b border-white/5">
      <div class="absolute top-0 left-0 w-full h-full bg-linear-to-br from-cyan-500/5 via-transparent to-purple-500/5 pointer-events-none"></div>
      <div class="absolute -top-40 -right-40 w-80 h-80 bg-cyan-500/10 blur-[120px] rounded-full"></div>
      <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-blue-600/10 blur-[120px] rounded-full"></div>

      <div class="max-w-5xl mx-auto relative z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-[10px] font-bold uppercase tracking-widest mb-6 anim-fade-in">
          <span class="w-1 h-1 rounded-full bg-cyan-400 animate-pulse"></span>
          {t('apiReference.developerInterface')}
        </div>
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight leading-[1.1] anim-fade-in">
          {t('apiReference.title').split(' ').map((word, i, arr) => (
            <>
              {word.toUpperCase() === 'API' ? <span class="text-gradient">API</span> : word}
              {i < arr.length - 1 && ' '}
            </>
          ))}
        </h1>
        <p class="text-slate-400 text-xl leading-relaxed max-w-2xl anim-fade-in delay-100">
          {t('apiReference.heroDesc')}
        </p>
      </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-5xl mx-auto px-8 py-20">
      <div class="grid grid-cols-1 gap-12">
        


        <!-- SDK Integration -->
        <section class="api-section anim-fade-in">
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-2xl bg-linear-to-br from-purple-400 to-pink-600 flex items-center justify-center text-white shadow-lg shadow-purple-500/20 text-xl">
              <Icon name="Box" size={24} />
            </div>
            <h2 class="text-3xl font-bold text-white tracking-tight">{t('apiReference.sdk.title')}</h2>
          </div>
          
          <div class="card p-8 space-y-12">
            <!-- Introduction -->
            <div>
              <p class="text-slate-400 text-lg leading-relaxed">
                {t('apiReference.sdk.description')}
              </p>
            </div>

            <!-- Installation -->
            <div>
              <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
                <span class="w-1.5 h-6 bg-purple-500 rounded-full"></span>
                {t('apiReference.sdk.installation')}
              </h3>
              <p class="text-slate-400 mb-6 text-sm">{t('apiReference.sdk.installDesc')}</p>
              
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                <!-- NPM -->
                <div class="bg-white/5 border border-white/10 rounded-xl p-4 hover:border-purple-500/50 transition-colors cursor-pointer group" onclick="navigator.clipboard.writeText('npm install @orange-ember/easy-flags-sdk')">
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-[10px] font-bold text-slate-500 uppercase tracking-wider">npm</span>
                    <Icon name="Copy" size={14} className="text-slate-500 group-hover:text-white" />
                  </div>
                  <code class="text-xs text-purple-300">npm install @orange-ember/easy-flags-sdk</code>
                </div>
                <!-- Yarn -->
                <div class="bg-white/5 border border-white/10 rounded-xl p-4 hover:border-purple-500/50 transition-colors cursor-pointer group" onclick="navigator.clipboard.writeText('yarn add @orange-ember/easy-flags-sdk')">
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-[10px] font-bold text-slate-500 uppercase tracking-wider">yarn</span>
                    <Icon name="Copy" size={14} className="text-slate-500 group-hover:text-white" />
                  </div>
                  <code class="text-xs text-purple-300">yarn add @orange-ember/easy-flags-sdk</code>
                </div>
                <!-- PNPM -->
                <div class="bg-white/5 border border-white/10 rounded-xl p-4 hover:border-purple-500/50 transition-colors cursor-pointer group" onclick="navigator.clipboard.writeText('pnpm add @orange-ember/easy-flags-sdk')">
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-[10px] font-bold text-slate-500 uppercase tracking-wider">pnpm</span>
                    <Icon name="Copy" size={14} className="text-slate-500 group-hover:text-white" />
                  </div>
                  <code class="text-xs text-purple-300">pnpm add @orange-ember/easy-flags-sdk</code>
                </div>
              </div>
            </div>

            <!-- Usage Steps -->
            <div class="space-y-10">
              <h3 class="text-xl font-bold text-white mb-2 flex items-center gap-2">
                <span class="w-1.5 h-6 bg-pink-500 rounded-full"></span>
                {t('apiReference.sdk.usage')}
              </h3>
              <p class="text-slate-400 text-sm -mt-2">{t('apiReference.sdk.usageDesc')}</p>
              
              <!-- Step 1: Init -->
              <div class="space-y-4">
                <h4 class="text-white font-bold text-sm tracking-wide">{t('apiReference.sdk.initTitle')}</h4>
                <p class="text-slate-400 text-sm">{t('apiReference.sdk.initDesc')}</p>
                <div class="relative overflow-hidden rounded-xl bg-[#0d1117] border border-white/10">
                  <div class="flex items-center justify-between px-4 py-2 border-b border-white/5 bg-white/2">
                    <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">JavaScript / TypeScript</span>
                    <button class="text-slate-500 hover:text-white transition-colors" onclick="navigator.clipboard.writeText(document.getElementById('init-code').innerText)">
                      <Icon name="Copy" size={14} />
                    </button>
                  </div>
                  <pre class="p-6 text-cyan-300 font-mono text-xs overflow-x-auto"><code id="init-code">import {'{'} EasyFlagsClient {'}'} from "@orange-ember/easy-flags-sdk";

const client = new EasyFlagsClient({'{'}
  apiKey: "YOUR_API_KEY",
  spaceId: "YOUR_SPACE_ID",
  environmentId: "YOUR_ENVIRONMENT_ID",
{'}'});</code></pre>
                </div>
              </div>

              <!-- Step 2: Evaluate -->
              <div class="space-y-4">
                <h4 class="text-white font-bold text-sm tracking-wide">{t('apiReference.sdk.evalTitle')}</h4>
                <p class="text-slate-400 text-sm">{t('apiReference.sdk.evalDesc')}</p>
                <div class="relative overflow-hidden rounded-xl bg-[#0d1117] border border-white/10">
                  <div class="flex items-center justify-between px-4 py-2 border-b border-white/5 bg-white/2">
                    <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">JavaScript</span>
                    <button class="text-slate-500 hover:text-white transition-colors" onclick="navigator.clipboard.writeText(document.getElementById('eval-code').innerText)">
                      <Icon name="Copy" size={14} />
                    </button>
                  </div>
                  <pre class="p-6 text-emerald-300 font-mono text-xs overflow-x-auto"><code id="eval-code">const isFeatureEnabled = await client.evaluate("new-navigation", {'{'}
  defaultValue: false,
{'}'});

if (isFeatureEnabled) {'{'}
  // Render new navigation
{'}'}</code></pre>
                </div>
              </div>

              <!-- Step 3: Advanced -->
              <div class="space-y-4">
                <h4 class="text-white font-bold text-sm tracking-wide">{t('apiReference.sdk.advancedTitle')}</h4>
                <p class="text-slate-400 text-sm">{t('apiReference.sdk.advancedDesc')}</p>
                <div class="relative overflow-hidden rounded-xl bg-[#0d1117] border border-white/10">
                  <div class="flex items-center justify-between px-4 py-2 border-b border-white/5 bg-white/2">
                    <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">TypeScript</span>
                    <button class="text-slate-500 hover:text-white transition-colors" onclick="navigator.clipboard.writeText(document.getElementById('advanced-code').innerText)">
                      <Icon name="Copy" size={14} />
                    </button>
                  </div>
                  <pre class="p-6 text-amber-300 font-mono text-xs overflow-x-auto"><code id="advanced-code">const themeColor = await client.evaluate&lt;string&gt;("user-theme", {'{'}
  defaultValue: "#ffffff",
  userId: "user_789", // Required for deterministic rollouts
  context: {'{'}
    plan: "premium",
    version: "2.4.0"
  {'}'}
{'}'});</code></pre>
                </div>
              </div>
            </div>

            <!-- Configuration Table -->
            <div>
              <h3 class="text-xl font-bold text-white mb-6 uppercase tracking-widest text-[10px] text-slate-500">
                {t('apiReference.sdk.configTitle')}
              </h3>
              <div class="overflow-hidden rounded-xl border border-white/10 bg-white/1">
                <table class="w-full text-left text-sm">
                  <thead class="bg-white/2 border-b border-white/10">
                    <tr>
                      <th class="px-6 py-4 font-bold text-white uppercase tracking-wider text-[10px]">Property</th>
                      <th class="px-6 py-4 font-bold text-white uppercase tracking-wider text-[10px]">Type</th>
                      <th class="px-6 py-4 font-bold text-white uppercase tracking-wider text-[10px]">Description</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-white/5">
                    <tr>
                      <td class="px-6 py-4 font-mono text-cyan-400 text-xs">apiKey</td>
                      <td class="px-6 py-4 text-slate-500 text-xs">string</td>
                      <td class="px-6 py-4 text-slate-300">{t('apiReference.sdk.configApiKey')}</td>
                    </tr>
                    <tr>
                      <td class="px-6 py-4 font-mono text-cyan-400 text-xs">spaceId</td>
                      <td class="px-6 py-4 text-slate-500 text-xs">string</td>
                      <td class="px-6 py-4 text-slate-300">{t('apiReference.sdk.configSpaceId')}</td>
                    </tr>
                    <tr>
                      <td class="px-6 py-4 font-mono text-cyan-400 text-xs">environmentId</td>
                      <td class="px-6 py-4 text-slate-500 text-xs">string</td>
                      <td class="px-6 py-4 text-slate-300">{t('apiReference.sdk.configEnvId')}</td>
                    </tr>
                    <tr>
                      <td class="px-6 py-4 font-mono text-cyan-400 text-xs">cacheTTL</td>
                      <td class="px-6 py-4 text-slate-500 text-xs">number</td>
                      <td class="px-6 py-4 text-slate-300">{t('apiReference.sdk.configCache')}</td>
                    </tr>
                    <tr>
                      <td class="px-6 py-4 font-mono text-cyan-400 text-xs">timeout</td>
                      <td class="px-6 py-4 text-slate-500 text-xs">number</td>
                      <td class="px-6 py-4 text-slate-300">{t('apiReference.sdk.configTimeout')}</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </section>

        <!-- Endpoints -->
        <section class="space-y-10">
          <div class="flex items-center gap-3 mb-2">
            <span class="h-px flex-1 bg-white/5"></span>
            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-[0.3em]">{t('apiReference.availableEndpoints')}</span>
            <span class="h-px flex-1 bg-white/5"></span>
          </div>

          <!-- Login -->
          <div class="card p-0 overflow-hidden group hover:border-blue-500/30 transition-all anim-fade-in delay-200">
            <div class="flex items-center justify-between px-8 py-5 border-b border-white/5 bg-white/2">
              <div class="flex items-center gap-3">
                <span class="px-2.5 py-1 rounded-md bg-blue-500/10 text-blue-400 text-[10px] font-black tracking-widest uppercase">POST</span>
                <code class="text-white font-bold text-sm tracking-tight">/api/auth/login</code>
              </div>
              <span class="opacity-50 group-hover:opacity-100 transition-opacity">
                <Icon name="Key" size={20} />
              </span>
            </div>
            <div class="p-8">
              <p class="text-slate-400 mb-0 leading-relaxed text-lg">
                {t('apiReference.loginDesc')}
              </p>
            </div>
          </div>

          <!-- Spaces -->
          <div class="card p-0 overflow-hidden group hover:border-purple-500/30 transition-all anim-fade-in delay-300">
            <div class="flex items-center justify-between px-8 py-5 border-b border-white/5 bg-white/2">
              <div class="flex items-center gap-3">
                <span class="px-2.5 py-1 rounded-md bg-emerald-500/10 text-emerald-400 text-[10px] font-black tracking-widest uppercase">GET</span>
                <code class="text-white font-bold text-sm tracking-tight">/api/spaces</code>
              </div>
              <span class="opacity-50 group-hover:opacity-100 transition-opacity">
                <Icon name="Box" size={20} />
              </span>
            </div>
            <div class="p-8">
              <p class="text-slate-400 mb-4 leading-relaxed text-lg">
                {t('apiReference.spacesDesc')}
              </p>
              <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-orange-500/10 border border-orange-500/20 text-orange-400 text-[10px] font-bold uppercase tracking-wider">
                <Icon name="Lock" size={12} />
                {t('apiReference.jwtAuth')}
              </div>
            </div>
          </div>

          <!-- Create Feature -->
          <div class="card p-0 overflow-hidden group hover:border-amber-500/30 transition-all anim-fade-in delay-400">
            <div class="flex items-center justify-between px-8 py-5 border-b border-white/5 bg-white/2">
              <div class="flex items-center gap-3">
                <span class="px-2.5 py-1 rounded-md bg-blue-500/10 text-blue-400 text-[10px] font-black tracking-widest uppercase">POST</span>
                <code class="text-white font-bold text-sm tracking-tight">/api/spaces/:spaceId/features</code>
              </div>
              <span class="opacity-50 group-hover:opacity-100 transition-opacity">
                <Icon name="Settings" size={20} />
              </span>
            </div>
            <div class="p-8">
              <p class="text-slate-400 mb-4 leading-relaxed text-lg">
                {t('apiReference.createFeatureDesc')}
              </p>
              <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-orange-500/10 border border-orange-500/20 text-orange-400 text-[10px] font-bold uppercase tracking-wider">
                <Icon name="Lock" size={12} />
                {t('apiReference.jwtAuth')}
              </div>
            </div>
          </div>

          <!-- Get Environments -->
          <div class="card p-0 overflow-hidden group hover:border-cyan-500/30 transition-all anim-fade-in delay-500">
            <div class="flex items-center justify-between px-8 py-5 border-b border-white/5 bg-white/2">
              <div class="flex items-center gap-3">
                <span class="px-2.5 py-1 rounded-md bg-emerald-500/10 text-emerald-400 text-[10px] font-black tracking-widest uppercase">GET</span>
                <code class="text-white font-bold text-sm tracking-tight">/api/spaces/:spaceId/environments</code>
              </div>
              <span class="opacity-50 group-hover:opacity-100 transition-opacity">
                <Icon name="Globe" size={20} />
              </span>
            </div>
            <div class="p-8">
              <p class="text-slate-400 mb-4 leading-relaxed text-lg">
                {t('apiReference.getEnvsDesc')}
              </p>
              <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-orange-500/10 border border-orange-500/20 text-orange-400 text-[10px] font-bold uppercase tracking-wider">
                <Icon name="Lock" size={12} />
                {t('apiReference.jwtAuth')}
              </div>
            </div>
          </div>

          <!-- Evaluate -->
          <div class="card p-0 overflow-hidden group hover:border-pink-500/30 transition-all anim-fade-in delay-600">
            <div class="flex items-center justify-between px-8 py-5 border-b border-white/5 bg-white/2">
              <div class="flex items-center gap-3">
                <span class="px-2.5 py-1 rounded-md bg-pink-500/10 text-pink-400 text-[10px] font-black tracking-widest uppercase">GET/POST</span>
                <code class="text-white font-bold text-sm tracking-tight">/api/features/:featureKey/evaluate</code>
              </div>
              <span class="opacity-50 group-hover:opacity-100 transition-opacity">
                <Icon name="Zap" size={20} />
              </span>
            </div>
            <div class="p-8">
              <p class="text-slate-400 mb-4 leading-relaxed text-lg">
                {t('apiReference.evaluateDesc')}
              </p>
              <div class="flex flex-wrap gap-3">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-orange-500/10 border border-orange-500/20 text-orange-400 text-[10px] font-bold uppercase tracking-wider">
                  <Icon name="Lock" size={12} />
                  {t('apiReference.jwtAuth')}
                </div>
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-[10px] font-bold uppercase tracking-wider">
                  <Icon name="Key" size={12} />
                  {t('apiReference.apiKeyAuth')}
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>

      <!-- Support Footer -->
      <div class="mt-40 relative group anim-fade-in delay-600">
        {/* Internal Aurora for the CTA */}
        <div class="absolute -inset-20 bg-cyan-500/5 blur-[120px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
        
        <div class="relative z-10 p-12 md:p-20 rounded-[48px] bg-white/[0.02] backdrop-blur-3xl border border-white/5 overflow-hidden shadow-2xl transition-all duration-700 hover:bg-white/[0.04] hover:border-white/10">
          <div class="absolute top-0 right-0 w-full h-full bg-linear-to-br from-cyan-500/[0.03] to-transparent pointer-events-none"></div>
          
          <div class="relative z-10 text-center max-w-2xl mx-auto">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-[10px] font-black uppercase tracking-widest mb-8">
              <span class="w-1.5 h-1.5 rounded-full bg-cyan-500 animate-pulse"></span>
              Enterprise Support
            </div>
            
            <h3 class="text-4xl md:text-5xl font-black text-white mb-6 tracking-tighter leading-tight">
              {t('apiReference.customIntegrationTitle')}
            </h3>
            
            <p class="text-slate-400 text-lg md:text-xl font-medium mb-12 leading-relaxed italic">
              " {t('apiReference.customIntegrationDesc')} "
            </p>
            
            <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
              <a href="/contact" class="btn-primary px-10! py-5! flex items-center justify-center gap-3 shadow-2xl shadow-cyan-500/20 group/btn w-full sm:w-auto">
                <span class="font-black text-xs uppercase tracking-widest">{t('apiReference.contactSupport')}</span>
                <Icon client:load name="ArrowRight" size={18} className="transition-transform duration-300 group-hover/btn:translate-x-1" />
              </a>
              <a href="/docs" class="text-[10px] font-black text-slate-500 uppercase tracking-[0.3em] hover:text-white transition-colors">
                Explore Documentation
              </a>
            </div>
          </div>
          
          <div class="mt-16 pt-8 border-t border-white/5 flex flex-col items-center">
             <p class="text-[9px] font-black text-slate-800 uppercase tracking-[0.5em]">DIRECT_LINK: ESTABLISHED &bull; LATENCY: 0.2MS &bull; ENCRYPTED</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .anim-fade-in {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .delay-100 { animation-delay: 0.1s; }
  .delay-200 { animation-delay: 0.2s; }
  .delay-300 { animation-delay: 0.3s; }
  .delay-400 { animation-delay: 0.4s; }
  .delay-500 { animation-delay: 0.5s; }
  .delay-600 { animation-delay: 0.6s; }

  @keyframes fadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .api-section {
    scroll-margin-top: 8rem;
  }
</style>
