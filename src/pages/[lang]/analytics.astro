---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AnalyticsDashboard from "@/components/react/analytics/AnalyticsDashboard";
import { requireAuth, getUserFromAstroContext, getLoginUrl } from "@/utils/auth-redirect";
import { hasFeatureAccess, FEATURES } from "@/utils/permissions";
import { getTranslator, getLocalizedPath } from "@/infrastructure/i18n/astro";

export const prerender = false;

// Check authentication
if (!requireAuth(Astro)) {
  return Astro.redirect(getLoginUrl(Astro));
}

// Get user and check feature access for analytics
const user = getUserFromAstroContext(Astro);
const { t, lang } = getTranslator(Astro.request);

const hasAccess = user && hasFeatureAccess(user, FEATURES.FEATURE_FLAGS);
if (!hasAccess) {
  return Astro.redirect(getLocalizedPath("/forbidden", lang as any));
}
---

<BaseLayout seoKey="analytics" includeHeader={true}>
  <div class="py-12">
    <AnalyticsDashboard client:load spaceId={undefined} />
  </div>
</BaseLayout>
