---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { requireAuth, getLoginUrl } from "@/utils/auth-redirect";
import { checkResourceExists } from "@/utils/resource-validation";
import EnvironmentsView from "@/components/react/environments/EnvironmentsView";
import { SpaceService } from "@application/services";

import { getLocale, getLocalizedPath } from "@/infrastructure/i18n/astro";

export const prerender = false;

// Require authentication (includes redirect parameter)
if (!requireAuth(Astro)) {
  return Astro.redirect(getLoginUrl(Astro));
}

const lang = getLocale(Astro.request);
const { spaceId: spaceSlug } = Astro.params;

// Verify space exists
const spaceService = new SpaceService();
const space = await spaceService.getSpaceBySlug(spaceSlug as string);
if (!checkResourceExists(space, Astro, "Space")) {
  return Astro.redirect(getLocalizedPath("/404", lang));
}

const initialLocale = lang;
---

<BaseLayout title={`${space?.name || "Space"} - Environments`} includeHeader={true}>
  <EnvironmentsView 
    client:load 
    spaceId={spaceSlug} 
    initialLocale={initialLocale}
    spaceName={space?.name}
  />
</BaseLayout>
