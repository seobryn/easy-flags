---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { requireAuth, getLoginUrl } from "@/utils/auth-redirect";
import { checkResourceExists } from "@/utils/resource-validation";
import { getUserFromContext } from "@/utils/auth";
import { isSuperUser } from "@/utils/permissions";
import PermissionsManagementView from "@/components/react/spaces/PermissionsManagementView";
import { SpaceService } from "@application/services";
import { getTranslator, getLocale } from "@/infrastructure/i18n/astro";

const { t } = getTranslator(Astro.request);
const initialLocale = getLocale(Astro.request);

export const prerender = false;

// Require authentication (includes redirect parameter)
if (!requireAuth(Astro)) {
  return Astro.redirect(getLoginUrl(Astro));
}

const { spaceId } = Astro.params;

// Verify space exists
const spaceService = new SpaceService();
const space = await spaceService.getSpaceBySlug(spaceId as string);

if (!checkResourceExists(space, Astro, "Space")) {
  return Astro.redirect("/404");
}

// Check if user is super user
const user = getUserFromContext(Astro);
const canManageFeaturePermissions = isSuperUser(user);
---

<BaseLayout title={`${t('spaces.accessControl')} - Easy Flags`} includeHeader={true}>
  <PermissionsManagementView
    client:load
    spaceId={spaceId}
    spaceName={space?.name}
    canManageFeaturePermissions={canManageFeaturePermissions}
    initialLocale={initialLocale}
  />
</BaseLayout>
