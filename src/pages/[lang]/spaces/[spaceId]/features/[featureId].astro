---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { requireAuth, getLoginUrl } from "@/utils/auth-redirect";
import {
  validateNestedResource,
  checkResourceExists,
} from "@/utils/resource-validation";
import AdvancedConfigurationView from "@/components/react/features/AdvancedConfigurationView";
import { SpaceService, FeatureService } from "@application/services";

export const prerender = false;

// Require authentication (includes redirect parameter)
if (!requireAuth(Astro)) {
  return Astro.redirect(getLoginUrl(Astro));
}

const { spaceId: spaceSlug, featureId } = Astro.params;
const featureIdNum = parseInt(featureId as string);

// Verify space exists first
const spaceService = new SpaceService();
const space = (await spaceService.getSpaceBySlug(spaceSlug as string))!;
if (!checkResourceExists(space, Astro, "Space")) {
  return Astro.redirect("/404");
}

// Verify feature exists and belongs to the space
const featureService = new FeatureService();
const feature = (await featureService.getFeature(featureIdNum))!;
if (!validateNestedResource(feature, "space_id", space.id, Astro, "Feature")) {
  return Astro.redirect("/404");
}

const title = `${feature.name} - Advanced Configuration`;
---

<BaseLayout title={title} includeHeader={true} fullWidth={true}>
  <AdvancedConfigurationView
    client:load
    spaceId={spaceSlug}
    spaceName={space.name}
    featureId={featureId}
    featureName={feature.name}
    featureKey={feature.key}
    featureType={feature.type}
  />
</BaseLayout>
