---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { requireAuth, getLoginUrl } from "@/utils/auth-redirect";
import { checkResourceExists } from "@/utils/resource-validation";
import FeaturesView from "@/components/react/features/FeaturesView";
import { SpaceService } from "@application/services";
import { getLocale } from "@/infrastructure/i18n/astro";

export const prerender = false;

const initialLocale = getLocale(Astro.request);

// Require authentication (includes redirect parameter)
if (!requireAuth(Astro)) {
  return Astro.redirect(getLoginUrl(Astro));
}

const { spaceId: spaceSlug } = Astro.params;

// Verify space exists
const spaceService = new SpaceService();
const space = await spaceService.getSpaceBySlug(spaceSlug as string);
if (!checkResourceExists(space, Astro, "Space")) {
  return Astro.redirect("/404");
}
---

<BaseLayout title="Features" includeHeader={true}>
  <FeaturesView client:load spaceId={spaceSlug} spaceName={space.name} initialLocale={initialLocale} />
</BaseLayout>
