---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Environments" includeHeader={true}>
  <div class="max-w-4xl mx-auto py-12">
    <h1 class="text-4xl font-bold text-gradient mb-6">Environments</h1>

    <div class="card">
      <p class="text-slate-400 mb-6">
        Create and manage environments. Define different feature flag configurations for Development, Staging, and Production.
      </p>

      <div class="bg-slate-700/50 border border-slate-600 rounded-lg p-4 text-center text-slate-400">
        <p>Environment management interface coming soon</p>
      </div>
    </div>
  </div>
</BaseLayout>
