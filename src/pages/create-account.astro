---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RegisterForm from "@/components/RegisterForm";
---

<BaseLayout title="Create Account - Feature Flags" includeHeader={false}>
  <div
    class="min-h-screen flex items-center justify-center px-4"
    style={{
      background:
        "linear-gradient(135deg, rgba(8, 47, 73, 0.98) 0%, rgba(6, 182, 212, 0.13) 40%)",
    }}
  >
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-gradient mb-2">Easy Flags</h1>
        <p class="text-slate-400">Create your account</p>
      </div>
      <RegisterForm client:load />
    </div>
  </div>
</BaseLayout>
