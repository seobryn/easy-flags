---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { redirectIfAuthenticated } from "@/utils/auth-redirect";
import RegisterForm from "@/components/react/auth/RegisterForm";
import { getTranslator } from "@/infrastructure/i18n/astro";

const { t } = getTranslator(Astro.request);

export const prerender = false;

// Redirect authenticated users to spaces
if (redirectIfAuthenticated(Astro)) {
  return Astro.redirect("/spaces");
}
---

<BaseLayout seoKey="createAccount" includeHeader={false}>
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-gradient mb-2">Easy Flags</h1>
        <p class="text-slate-400">{t('auth.createYourAccount')}</p>
      </div>
      <RegisterForm client:load />
    </div>
  </div>
</BaseLayout>
