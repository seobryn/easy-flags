{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "jsxImportSource": "react",
        "strictNullChecks": true,
        "resolveJsonModule": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@components/*": [
                "src/components/*"
            ],
            "@layouts/*": [
                "src/layouts/*"
            ],
            "@utils/*": [
                "src/utils/*"
            ],
            "@api/*": [
                "src/api/*"
            ]
        }
    }
}