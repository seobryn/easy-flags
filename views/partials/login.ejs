<!-- Login Screen -->
<div id="login" class="fixed inset-0 flex items-center justify-center p-4">
  <div class="login-card card max-w-lg relative">
    <div id="loginMsg" class="space-y-1"></div>

    <a
      href="/"
      class="small muted back-link"
      style="
        position: absolute;
        top: 12px;
        left: 12px;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
      "
      aria-label="Back to home"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <polyline
          points="15 18 9 12 15 6"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
      </svg>
      <span>Back to home</span>
    </a>

    <div class="login-brand">
      <div class="logo login">FF</div>
      <div>
        <h2 class="text-cyan-accent mb-1 text-2xl font-bold">Welcome back</h2>
        <p class="small muted">Manage feature flags across environments</p>
      </div>
    </div>

    <form id="loginForm" class="login-form">
      <input
        id="username"
        placeholder="Username"
        type="text"
        autocomplete="username"
      />
      <input
        id="password"
        placeholder="Password"
        type="password"
        autocomplete="current-password"
      />
      <button id="btnLogin" class="primary w-full mt-6" type="submit">
        Sign in
      </button>
    </form>
    <!-- discrete back link replaces big CTA -->
  </div>
</div>

<script src="/js/login.js"></script>
