<% 
  const currentPath = typeof path !== 'undefined' ? path : '';
  const isActivePath = (href) => {
    if (href === '/') return currentPath === '/';
    return currentPath.startsWith(href);
  };
%>
<!-- Header / Navigation (unified) -->
<div class="top flex items-center justify-between py-4">
  <div class="flex items-center gap-3 flex-1 min-w-0">
    <a href="/" class="logo header text-lg font-bold text-white no-underline" aria-label="Home">EF</a>
    <h2 class="text-base sm:text-xl md:text-2xl font-bold truncate">Easy Flags</h2>
  </div>

  <div class="flex items-center gap-2">
    <button
      id="hamburger"
      class="icon-btn sm:hidden"
      aria-label="Menu"
      aria-controls="mainNav"
      aria-expanded="false"
      type="button"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M3 6h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M3 12h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <!-- Nav menu (inside header; styled as drawer on mobile) -->
    <div class="nav-placeholder hidden sm:block" aria-hidden="true">
      <nav class="nav flex gap-2 items-center" id="mainNav" role="navigation" aria-label="Main navigation">
        <% if (typeof user !== 'undefined' && user) { %>
          <% if (permissions && permissions.includes('view_environments')) { %>
            <a href="/environments" class="nav-btn<%= isActivePath('/environments') ? ' active' : '' %>" data-nav="envs">Environments</a>
          <% } %>
          <% if (permissions && permissions.includes('view_features')) { %>
            <a href="/features" class="nav-btn<%= isActivePath('/features') ? ' active' : '' %>" data-nav="features">Feature Flags</a>
          <% } %>
          <% if (permissions && permissions.includes('view_users')) { %>
            <a href="/users" class="nav-btn<%= isActivePath('/users') ? ' active' : '' %>" data-nav="users">Users</a>
          <% } %>
          <% if (permissions && permissions.includes('view_roles')) { %>
            <a href="/roles" class="nav-btn<%= isActivePath('/roles') ? ' active' : '' %>" data-nav="roles">Roles</a>
          <% } %>
          <a href="/docs" class="nav-btn<%= isActivePath('/docs') ? ' active' : '' %>" data-nav="docs">Docs</a>
          <a href="/api-reference" class="nav-btn<%= isActivePath('/api-reference') ? ' active' : '' %>">API</a>
          <button id="btnLogout" type="button" class="nav-btn">Logout</button>
        <% } else { %>
          <a href="/billing" class="nav-btn" data-nav="pricing">Pricing</a>
          <a href="/api-reference" class="nav-btn" data-nav="docs">API</a>
          <a href="/login" class="nav-btn" data-nav="login">Login</a>
        <% } %>
      </nav>
    </div>
  </div>

</div>

<!-- Mobile drawer & backdrop (placed outside header to avoid layout interference) -->
<div id="navBackdrop" style="z-index:9998; display:none;" class="fixed inset-0 bg-black/60 transition-opacity opacity-0 pointer-events-none sm:hidden" aria-hidden="true"></div>

<nav id="mobileNav" style="z-index:9999" class="-translate-x-full fixed inset-y-0 left-0 w-64 bg-slate-900 backdrop-blur p-6 transform transition-transform sm:hidden" aria-hidden="true">
  <div class="flex items-center justify-between mb-6">
    <a href="/" class="logo header text-lg font-bold text-white no-underline">EF</a>
    <button id="mobileClose" class="text-slate-400 text-2xl leading-none" aria-label="Close menu">×</button>
  </div>
  <% if (typeof user !== 'undefined' && user) { %>
    <% if (permissions && permissions.includes('view_environments')) { %>
      <a href="/environments" class="nav-btn block w-full text-left py-2<%= isActivePath('/environments') ? ' active' : '' %>" data-nav="envs">Environments</a>
    <% } %>
    <% if (permissions && permissions.includes('view_features')) { %>
      <a href="/features" class="nav-btn block w-full text-left py-2<%= isActivePath('/features') ? ' active' : '' %>" data-nav="features">Feature Flags</a>
    <% } %>
    <% if (permissions && permissions.includes('view_users')) { %>
      <a href="/users" class="nav-btn block w-full text-left py-2<%= isActivePath('/users') ? ' active' : '' %>" data-nav="users">Users</a>
    <% } %>
    <% if (permissions && permissions.includes('view_roles')) { %>
      <a href="/roles" class="nav-btn block w-full text-left py-2<%= isActivePath('/roles') ? ' active' : '' %>" data-nav="roles">Roles</a>
    <% } %>
    <a href="/docs" class="nav-btn block w-full text-left py-2<%= isActivePath('/docs') ? ' active' : '' %>" data-nav="docs">Docs</a>
    <a href="/api-reference" class="nav-btn block w-full text-left py-2<%= isActivePath('/api-reference') ? ' active' : '' %>">API</a>
    <button id="btnLogoutMobile" type="button" class="nav-btn block w-full text-left py-2">Logout</button>
  <% } else { %>
    <a href="/billing" class="nav-btn block w-full text-left py-2" data-nav="pricing">Pricing</a>
    <a href="/api-reference" class="nav-btn block w-full text-left py-2" data-nav="docs">API</a>
    <a href="/login" class="nav-btn block w-full text-left py-2" data-nav="login">Login</a>
  <% } %>
</nav>


<script>
  window.USER_PERMISSIONS = <%- JSON.stringify(typeof permissions !== 'undefined' ? permissions : []) %>;
</script>
<script src="/js/header.js"></script>
