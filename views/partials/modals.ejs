<!-- Modals -->
<!-- Create Feature Modal -->
<div
  id="modal"
  class="fixed inset-0 flex items-start sm:items-center justify-center bg-black/40 z-50 p-4 hidden"
>
  <div
    class="bg-slate-900/95 rounded-lg p-6 w-full max-w-lg shadow-lg border border-white/6"
  >
    <form id="featureModalForm" class="space-y-4">
      <h3 class="text-xl font-bold text-slate-100">Create Feature</h3>
      <input
        id="modalFeatureKey"
        placeholder="Feature key (e.g., new_ui)"
        type="text"
        class="block w-full bg-white/5 text-white placeholder-slate-400 px-3 py-2 rounded-md border border-white/10 focus:outline-none focus:ring-2 focus:ring-cyan-500"
      />
      <input
        id="modalFeatureDesc"
        placeholder="Description"
        type="text"
        class="block w-full bg-white/5 text-white placeholder-slate-400 px-3 py-2 rounded-md border border-white/10 focus:outline-none focus:ring-2 focus:ring-cyan-500"
      />
      <label class="text-sm text-slate-400 block">
        Initialize for environment (optional)
      </label>
      <select
        id="modalEnvSelect"
        class="block w-full bg-white/5 text-white placeholder-slate-400 px-3 py-2 rounded-md border border-white/10"
      >
        <option value="">-- none --</option>
      </select>
      <div class="mt-4 flex items-center gap-3">
        <label class="toggle-switch">
          <input id="modalEnvToggle" type="checkbox" />
          <span class="slider"></span>
        </label>
        <div class="text-sm text-slate-400">
          Activate in selected environment
        </div>
      </div>
      <div id="modalMsg" class="text-sm mt-3"></div>
      <div
        class="flex flex-col-reverse sm:flex-row justify-end gap-2 mt-6 space-y-reverse"
      >
        <button
          id="modalCreate"
          class="bg-cyan-500 text-white px-4 py-2 rounded-md"
          type="submit"
        >
          Create
        </button>
        <button
          id="modalClose"
          class="border border-white/10 text-white px-4 py-2 rounded-md"
          type="button"
        >
          Cancel
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Create / Edit Environment Modal -->
<div
  id="envModal"
  class="fixed inset-0 flex items-start sm:items-center justify-center bg-black/40 z-50 p-4 hidden"
>
  <div
    class="bg-slate-900/95 rounded-lg p-6 w-full max-w-lg shadow-lg border border-white/6"
  >
    <form id="envModalForm" class="space-y-4">
      <h3 id="envModalTitle" class="text-xl font-bold text-slate-100">
        Create Environment
      </h3>
      <input
        id="envModalName"
        placeholder="Environment name (e.g., staging)"
        type="text"
        class="block w-full bg-white/5 text-white placeholder-slate-400 px-3 py-2 rounded-md border border-white/10 focus:outline-none focus:ring-2 focus:ring-cyan-500"
      />
      <div id="envModalMsg" class="text-sm mt-3"></div>
      <div
        class="flex flex-col-reverse sm:flex-row justify-end gap-2 mt-6 space-y-reverse"
      >
        <button
          id="modalEnvSave"
          class="bg-cyan-500 text-white px-4 py-2 rounded-md"
          type="submit"
        >
          Save
        </button>
        <button
          id="modalEnvClose"
          class="border border-white/10 text-white px-4 py-2 rounded-md"
          type="button"
        >
          Cancel
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Create / Edit User Modal -->
<div
  id="userModal"
  class="fixed inset-0 flex items-start sm:items-center justify-center bg-black/40 z-50 p-4 hidden"
>
  <div
    class="bg-slate-900/95 rounded-lg p-6 w-full max-w-lg shadow-lg border border-white/6"
  >
    <form id="userModalForm" class="space-y-3">
      <h3 id="userModalTitle" class="text-xl font-bold text-slate-100">
        Create User
      </h3>
      <input
        id="userModalUsername"
        placeholder="Username"
        type="text"
        autocomplete="username"
        class="block w-full bg-white/5 text-white placeholder-slate-400 px-3 py-2 rounded-md border border-white/10 focus:outline-none focus:ring-2 focus:ring-cyan-500"
      />
      <input
        id="userModalPassword"
        placeholder="Password"
        type="password"
        autocomplete="new-password"
        class="block w-full bg-white/5 text-white placeholder-slate-400 px-3 py-2 rounded-md border border-white/10 focus:outline-none focus:ring-2 focus:ring-cyan-500"
      />
      <label for="userModalRole" class="text-sm text-slate-400 block mt-2"
        >Role</label
      >
      <select
        id="userModalRole"
        class="block w-full bg-white/5 text-white placeholder-slate-400 px-3 py-2 rounded-md border border-white/10"
      >
        <option value="">-- Select a role --</option>
      </select>
      <div id="userModalMsg" class="text-sm mt-1 text-amber-300"></div>
      <div
        class="flex flex-col-reverse sm:flex-row justify-end gap-2 mt-4 space-y-reverse"
      >
        <button
          id="modalUserSave"
          class="bg-cyan-500 text-white px-4 py-2 rounded-md"
          type="submit"
        >
          Save
        </button>
        <button
          id="modalUserClose"
          class="border border-white/10 text-white px-4 py-2 rounded-md"
          type="button"
        >
          Cancel
        </button>
      </div>
    </form>
  </div>
</div>
