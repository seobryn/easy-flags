<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Feature Flags UI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/style.css" />
    <link rel="stylesheet" href="/styles/landing.css" />
  </head>
  <body
    class="antialiased bg-gradient-to-br from-slate-900 via-slate-800 to-cyan-950"
  >
    <div class="root h-full">
      <div class="top">
        <div class="flex items-center gap-3 flex-1 min-w-0">
          <div class="logo header">FF</div>
          <h2 class="text-base sm:text-xl md:text-2xl font-bold truncate">
            Easy Flags
          </h2>
        </div>
        <div class="nav hidden sm:flex">
          <button
            type="button"
            class="nav-btn"
            onclick="window.location.href = '/login'"
          >
            Login
          </button>
          <button
            type="button"
            class="nav-btn"
            onclick="window.location.href = '/api/openapi.json'"
          >
            API
          </button>
        </div>
      </div>

      <div class="container mt-6 p-4 space-y-4">
        <!-- Hero -->
        <section class="mt-6">
          <div class="space-y-4">
            <div class="w-full hero-panel">
              <!-- SVG hero (unchanged) -->
              <svg
                viewBox="0 0 800 360"
                role="img"
                aria-label="Feature rollout illustration"
              >
                <defs>
                  <linearGradient
                    id="heroGradient"
                    x1="0%"
                    y1="0%"
                    x2="100%"
                    y2="0%"
                  >
                    <stop offset="0%" stop-color="var(--accent)" />
                    <stop offset="100%" stop-color="var(--accent-2)" />
                  </linearGradient>
                  <linearGradient
                    id="heroGradientSoft"
                    x1="0%"
                    y1="0%"
                    x2="0%"
                    y2="100%"
                  >
                    <stop offset="0%" stop-color="rgba(6,182,212,0.2)" />
                    <stop offset="100%" stop-color="rgba(6,182,212,0.03)" />
                  </linearGradient>
                </defs>
                <rect
                  x="24"
                  y="24"
                  width="752"
                  height="312"
                  rx="28"
                  fill="rgba(255,255,255,0.04)"
                />
                <rect
                  x="56"
                  y="56"
                  width="688"
                  height="248"
                  rx="22"
                  fill="url(#heroGradientSoft)"
                  stroke="rgba(255,255,255,0.08)"
                />
                <rect
                  x="88"
                  y="86"
                  width="210"
                  height="18"
                  rx="9"
                  fill="url(#heroGradient)"
                />
                <rect
                  x="88"
                  y="118"
                  width="340"
                  height="12"
                  rx="6"
                  fill="rgba(255,255,255,0.14)"
                />
                <rect
                  x="88"
                  y="142"
                  width="300"
                  height="12"
                  rx="6"
                  fill="rgba(255,255,255,0.12)"
                />
                <rect
                  x="88"
                  y="178"
                  width="218"
                  height="102"
                  rx="18"
                  fill="rgba(255,255,255,0.06)"
                />
                <rect
                  x="326"
                  y="178"
                  width="218"
                  height="102"
                  rx="18"
                  fill="rgba(255,255,255,0.06)"
                />
                <rect
                  x="564"
                  y="178"
                  width="152"
                  height="102"
                  rx="18"
                  fill="rgba(255,255,255,0.06)"
                />
                <line
                  x1="197"
                  y1="229"
                  x2="435"
                  y2="229"
                  stroke="rgba(255,255,255,0.18)"
                  stroke-width="2"
                />
                <line
                  x1="435"
                  y1="229"
                  x2="640"
                  y2="229"
                  stroke="rgba(255,255,255,0.18)"
                  stroke-width="2"
                />
                <circle
                  class="hero-dot hero-dot-1"
                  cx="197"
                  cy="229"
                  r="13"
                  fill="url(#heroGradient)"
                />
                <circle
                  class="hero-dot hero-dot-2"
                  cx="435"
                  cy="229"
                  r="13"
                  fill="url(#heroGradient)"
                />
                <circle
                  class="hero-dot hero-dot-3"
                  cx="640"
                  cy="229"
                  r="13"
                  fill="url(#heroGradient)"
                />
                <rect
                  x="118"
                  y="242"
                  width="64"
                  height="10"
                  rx="5"
                  fill="rgba(255,255,255,0.18)"
                />
                <rect
                  x="356"
                  y="242"
                  width="64"
                  height="10"
                  rx="5"
                  fill="rgba(255,255,255,0.18)"
                />
                <rect
                  class="hero-cta"
                  x="596"
                  y="212"
                  width="88"
                  height="34"
                  rx="17"
                  fill="rgba(6,182,212,0.2)"
                  stroke="rgba(6,182,212,0.45)"
                />
                <circle cx="665" cy="229" r="12" fill="url(#heroGradient)" />
                <circle cx="684" cy="96" r="16" fill="url(#heroGradient)" />
                <circle cx="712" cy="96" r="7" fill="rgba(255,255,255,0.3)" />
              </svg>
            </div>

            <div>
              <h1 class="text-cyan-accent text-2xl font-bold mb-1">
                Launch new ideas without the stress.
              </h1>
              <p class="small muted">
                Release in smaller steps, stay in control, and adapt instantly.
              </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-2">
              <button
                type="button"
                class="primary w-full sm:w-auto"
                onclick="window.location.href = '/login'"
              >
                Get Started
              </button>
              <button
                type="button"
                class="ghost w-full sm:w-auto"
                onclick="window.location.href = '/api/openapi.json'"
              >
                API Reference
              </button>
            </div>
          </div>
        </section>

        <!-- Features -->
        <section class="mt-6">
          <div class="mb-4">
            <h3 class="mb-1">Why people love using Easy Flags</h3>
            <p class="small muted">Simple, clear, and built for fast teams.</p>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mt-6">
            <div class="flex-1 feature-tile">
              <div class="feature-badge badge-accent">
                <img class="icon" src="/icons/rocket.svg" alt="Rocket" />
              </div>
              <div>
                <p class="small small-strong">Faster releases</p>
                <p class="small muted">Ship in smaller steps.</p>
              </div>
            </div>
            <div class="flex-1 feature-tile">
              <div class="feature-badge badge-green">
                <img class="icon" src="/icons/target.svg" alt="Target" />
              </div>
              <div>
                <p class="small small-strong">More control</p>
                <p class="small muted">Toggle anytime.</p>
              </div>
            </div>
            <div class="flex-1 feature-tile">
              <div class="feature-badge badge-purple">
                <img class="icon" src="/icons/heart.svg" alt="Heart" />
              </div>
              <div>
                <p class="small small-strong">Better UX</p>
                <p class="small muted">Improve what users feel.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Comparisons -->
        <section class="mt-6">
          <div class="mb-4">
            <h3 class="mb-1">Simple journeys, real impact</h3>
            <p class="small muted">
              Each comparison shows how Easy Flags turns friction into faster,
              safer delivery.
            </p>
          </div>

          <div class="flex flex-col gap-3">
            <div class="comparison-tile mt-6">
              <div class="flex items-center justify-between tile-header">
                <div class="flex items-center gap-3">
                  <div class="comparison-badge badge-accent">
                    <img class="icon" src="/icons/rocket.svg" alt="Rocket" />
                  </div>
                  <p class="small small-strong">Launches</p>
                </div>
                <p class="small muted">Before → After</p>
              </div>
              <div class="cmp-graph" role="img" aria-label="Launches before and after">
                <div class="cmp-bar-row">
                  <div class="cmp-label">Before</div>
                  <div class="cmp-bar">
                    <div class="cmp-fill cmp-before" style="width:40%">40%</div>
                  </div>
                </div>
                <div class="cmp-bar-row">
                  <div class="cmp-label">After</div>
                  <div class="cmp-bar">
                    <div class="cmp-fill cmp-after" style="width:72%">72%</div>
                  </div>
                </div>
              </div>
              <p class="small muted mt-3">
                Move from risky all-at-once launches to progressive rollouts
                with better control.
              </p>
            </div>

            <div class="comparison-tile mt-6">
              <div class="flex items-center justify-between tile-header">
                <div class="flex items-center gap-3">
                  <div class="comparison-badge badge-green">
                    <img
                      class="icon"
                      src="/icons/lifebuoy.svg"
                      alt="Lifebuoy"
                    />
                  </div>
                  <p class="small small-strong">Reliability</p>
                </div>
                <p class="small muted">Before → After</p>
              </div>
              <div class="cmp-graph" role="img" aria-label="Reliability before and after">
                <div class="cmp-bar-row">
                  <div class="cmp-label">Before</div>
                  <div class="cmp-bar">
                    <div class="cmp-fill cmp-before" style="width:60%">60%</div>
                  </div>
                </div>
                <div class="cmp-bar-row">
                  <div class="cmp-label">After</div>
                  <div class="cmp-bar">
                    <div class="cmp-fill cmp-after" style="width:88%">88%</div>
                  </div>
                </div>
              </div>
              <p class="small muted mt-3">
                Reduce downtime by switching unstable features off instantly
                instead of waiting for a redeploy.
              </p>
            </div>

            <div class="comparison-tile mt-6">
              <div class="flex items-center justify-between tile-header">
                <div class="flex items-center gap-3">
                  <div class="comparison-badge badge-purple">
                    <img
                      class="icon"
                      src="/icons/sparkles.svg"
                      alt="Sparkles"
                    />
                  </div>
                  <p class="small small-strong">Product fit</p>
                </div>
                <p class="small muted">Before → After</p>
              </div>
              <div class="cmp-graph" role="img" aria-label="Product fit before and after">
                <div class="cmp-bar-row">
                  <div class="cmp-label">Before</div>
                  <div class="cmp-bar">
                    <div class="cmp-fill cmp-before" style="width:33%">33%</div>
                  </div>
                </div>
                <div class="cmp-bar-row">
                  <div class="cmp-label">After</div>
                  <div class="cmp-bar">
                    <div class="cmp-fill cmp-after" style="width:76%">76%</div>
                  </div>
                </div>
              </div>
              <p class="small muted mt-3">
                Replace guesswork with fast experiments and measurable learning
                across environments.
              </p>
            </div>
          </div>
        </section>

        <!-- CTA -->
        <section class="mt-6">
          <div class="flex flex-col md:flex-row gap-4">
            <div class="flex-1 space-y-4">
              <div class="flex items-center gap-3">
                <div class="cta-badge">
                  <img class="icon" src="/icons/bolt.svg" alt="Bolt" />
                </div>
                <div>
                  <h3>Ready to launch with confidence?</h3>
                  <p class="small muted">
                    Fast setup. Clear control. Safer releases.
                  </p>
                </div>
              </div>

              <div class="checklist-panel">
                <p class="small muted">
                  <img
                    class="icon inline-check"
                    src="/icons/check.svg"
                    alt="Check"
                  />
                  Manage all flags in one place
                </p>
                <p class="small muted">
                  <img
                    class="icon inline-check"
                    src="/icons/check.svg"
                    alt="Check"
                  />
                  Roll out changes with less risk
                </p>
                <p class="small muted">
                  <img
                    class="icon inline-check"
                    src="/icons/check.svg"
                    alt="Check"
                  />
                  Improve user experience continuously
                </p>
              </div>

              <div class="flex flex-col sm:flex-row gap-2">
                <button
                  type="button"
                  class="primary w-full sm:w-auto"
                  onclick="window.location.href = '/login'"
                >
                  Start Now
                </button>
                <button
                  type="button"
                  class="ghost w-full sm:w-auto"
                  onclick="window.location.href = '/api/openapi.json'"
                >
                  View API Spec
                </button>
              </div>

              <p class="small muted">
                No complex setup. Create flags and ship.
              </p>
            </div>

            <div class="w-full max-w-lg panel-right">
              <svg
                viewBox="0 0 420 220"
                role="img"
                aria-label="Quick start illustration"
              >
                <rect
                  class="qs-card"
                  x="16"
                  y="16"
                  width="388"
                  height="188"
                  rx="18"
                  fill="rgba(255,255,255,0.03)"
                  stroke="rgba(255,255,255,0.1)"
                />
                <rect
                  class="qs-topbar"
                  x="40"
                  y="46"
                  width="152"
                  height="14"
                  rx="7"
                  fill="rgba(6,182,212,0.75)"
                />
                <rect
                  class="qs-line"
                  x="40"
                  y="72"
                  width="230"
                  height="10"
                  rx="5"
                  fill="rgba(255,255,255,0.2)"
                />
                <rect
                  class="qs-line"
                  x="40"
                  y="96"
                  width="188"
                  height="10"
                  rx="5"
                  fill="rgba(255,255,255,0.14)"
                />
                <rect
                  class="qs-chip"
                  x="40"
                  y="128"
                  width="104"
                  height="44"
                  rx="12"
                  fill="rgba(255,255,255,0.06)"
                />
                <rect
                  class="qs-chip"
                  x="158"
                  y="128"
                  width="104"
                  height="44"
                  rx="12"
                  fill="rgba(255,255,255,0.06)"
                />
                <rect
                  class="qs-chip"
                  x="276"
                  y="128"
                  width="104"
                  height="44"
                  rx="12"
                  fill="rgba(255,255,255,0.06)"
                />
                <circle
                  class="qs-badge"
                  cx="332"
                  cy="54"
                  r="11"
                  fill="rgba(6,182,212,0.78)"
                />
                <rect
                  class="qs-cta"
                  x="300"
                  y="84"
                  width="72"
                  height="30"
                  rx="15"
                  fill="rgba(6,182,212,0.2)"
                  stroke="rgba(6,182,212,0.5)"
                />
                <circle
                  class="qs-cta-dot"
                  cx="355"
                  cy="99"
                  r="10"
                  fill="rgba(6,182,212,0.9)"
                />
              </svg>
            </div>
          </div>
        </section>
      </div>
      <%- include('partials/footer') %>
    </div>
  </body>
</html>
