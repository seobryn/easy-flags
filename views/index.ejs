<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Feature Flags UI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/style.css" />
    <link rel="stylesheet" href="/styles/landing.css" />
  </head>
  <body
    class="antialiased bg-gradient-to-br from-slate-900 via-slate-800 to-cyan-950"
  >
    <div class="root h-full">
      <div class="top">
        <div class="flex items-center gap-3 flex-1 min-w-0">
          <div class="logo header">FF</div>
          <h2 class="text-base sm:text-xl md:text-2xl font-bold truncate">
            Easy Flags
          </h2>
        </div>
        <div class="nav hidden sm:flex">
          <button
            type="button"
            class="nav-btn"
            onclick="window.location.href = '/login'"
          >
            Login
          </button>
          <button
            type="button"
            class="nav-btn"
            onclick="window.location.href = '/api/openapi.json'"
          >
            API
          </button>
        </div>
      </div>

      <div class="container mt-6 p-4 space-y-4">
        <!-- Hero -->
        <section class="mt-6">
          <div class="space-y-4">
            <div class="w-full hero-panel">
              <!-- External SVG: hero illustration -->
              <img
                class="hero-illustration"
                src="/illustrations/hero.svg"
                alt="Feature rollout illustration"
              />
            </div>

            <div>
              <h1 class="text-cyan-accent text-2xl font-bold mb-1">
                Launch new ideas without the stress.
              </h1>
              <p class="small muted">
                Release in smaller steps, stay in control, and adapt instantly.
              </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-2">
              <button
                type="button"
                class="primary w-full sm:w-auto"
                onclick="window.location.href = '/login'"
              >
                Get Started
              </button>
              <button
                type="button"
                class="ghost w-full sm:w-auto"
                onclick="window.location.href = '/api/openapi.json'"
              >
                API Reference
              </button>
            </div>
          </div>
        </section>

        <!-- Features -->
        <section class="mt-6">
          <div class="mb-4">
            <h3 class="mb-1">Why people love using Easy Flags</h3>
            <p class="small muted">Simple, clear, and built for fast teams.</p>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mt-6">
            <div class="flex-1 feature-tile">
              <div class="feature-badge badge-accent">
                <img class="icon" src="/icons/rocket.svg" alt="Rocket" />
              </div>
              <div>
                <p class="small small-strong">Faster releases</p>
                <p class="small muted">Ship in smaller steps.</p>
              </div>
            </div>
            <div class="flex-1 feature-tile">
              <div class="feature-badge badge-green">
                <img class="icon" src="/icons/target.svg" alt="Target" />
              </div>
              <div>
                <p class="small small-strong">More control</p>
                <p class="small muted">Toggle anytime.</p>
              </div>
            </div>
            <div class="flex-1 feature-tile">
              <div class="feature-badge badge-purple">
                <img class="icon" src="/icons/heart.svg" alt="Heart" />
              </div>
              <div>
                <p class="small small-strong">Better UX</p>
                <p class="small muted">Improve what users feel.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Comparisons -->
        <section class="mt-6">
          <div class="mb-4">
            <h3 class="mb-1">Simple journeys, real impact</h3>
            <p class="small muted">
              Each comparison shows how Easy Flags turns friction into faster,
              safer delivery.
            </p>
          </div>

          <div class="comparisons-grid">
            <div class="comparison-tile mt-6">
              <div class="flex items-center justify-between tile-header">
                <div class="flex items-center gap-3">
                  <div class="comparison-badge badge-accent">
                    <img class="icon" src="/icons/check.svg" alt="Check" />
                  </div>
                  <p class="small small-strong">Launches</p>
                </div>
                <p class="small muted">Before → After</p>
              </div>
              <div
                class="cmp-graph"
                role="img"
                aria-label="Launches: time to release"
              >
                <img
                  class="cmp-compare"
                  src="/illustrations/compare-launches.svg"
                  alt="Launches before and after"
                />
              </div>
              <p class="small muted mt-3">
                Move from risky all-at-once launches to progressive rollouts
                with better control.
              </p>
            </div>

            <div class="comparison-tile mt-6">
              <div class="flex items-center justify-between tile-header">
                <div class="flex items-center gap-3">
                  <div class="comparison-badge badge-green">
                    <img
                      class="icon"
                      src="/icons/lifebuoy.svg"
                      alt="Lifebuoy"
                    />
                  </div>
                  <p class="small small-strong">Reliability</p>
                </div>
                <p class="small muted">Before → After</p>
              </div>
              <div
                class="cmp-graph"
                role="img"
                aria-label="Reliability: incidents per month"
              >
                <img
                  class="cmp-compare"
                  src="/illustrations/compare-reliability.svg"
                  alt="Reliability before and after"
                />
              </div>
              <p class="small muted mt-3">
                Reduce downtime by switching unstable features off instantly
                instead of waiting for a redeploy.
              </p>
            </div>

            <div class="comparison-tile mt-6">
              <div class="flex items-center justify-between tile-header">
                <div class="flex items-center gap-3">
                  <div class="comparison-badge badge-purple">
                    <img
                      class="icon"
                      src="/icons/sparkles.svg"
                      alt="Sparkles"
                    />
                  </div>
                  <p class="small small-strong">Product fit</p>
                </div>
                <p class="small muted">Before → After</p>
              </div>
              <div
                class="cmp-graph"
                role="img"
                aria-label="Product fit: % features validated"
              >
                <img
                  class="cmp-compare"
                  src="/illustrations/compare-productfit.svg"
                  alt="Product fit before and after"
                />
              </div>
              <p class="small muted mt-3">
                Replace guesswork with fast experiments and measurable learning
                across environments.
              </p>
            </div>

            <div class="comparison-tile mt-6">
              <div class="flex items-center justify-between tile-header">
                <div class="flex items-center gap-3 justify-center">
                  <div class="comparison-badge badge-accent">
                    <img class="icon" src="/icons/bolt.svg" alt="Bolt" />
                  </div>
                  <p class="small small-strong">Deployment Frequency</p>
                </div>
                <p class="small muted">Before → After</p>
              </div>
              <div
                class="cmp-graph"
                role="img"
                aria-label="Deployment frequency per week"
              >
                <img
                  class="cmp-compare"
                  src="/illustrations/compare-frequency.svg"
                  alt="Deployment frequency before and after"
                />
              </div>
              <p class="small muted mt-3">
                Deploy changes multiple times a day instead of waiting for
                weekly releases.
              </p>
            </div>
          </div>
        </section>

        <!-- CTA -->
        <section class="mt-6">
          <div class="flex flex-col md:flex-row gap-4">
            <div class="flex-1 space-y-4">
              <div class="flex items-center gap-3">
                <div class="cta-badge">
                  <img class="icon" src="/icons/bolt.svg" alt="Bolt" />
                </div>
                <div>
                  <h3>Ready to launch with confidence?</h3>
                  <p class="small muted">
                    Fast setup. Clear control. Safer releases.
                  </p>
                </div>
              </div>

              <div class="checklist-panel">
                <p class="small muted">
                  <img
                    class="icon inline-check"
                    src="/icons/check.svg"
                    alt="Check"
                  />
                  Manage all flags in one place
                </p>
                <p class="small muted">
                  <img
                    class="icon inline-check"
                    src="/icons/check.svg"
                    alt="Check"
                  />
                  Roll out changes with less risk
                </p>
                <p class="small muted">
                  <img
                    class="icon inline-check"
                    src="/icons/check.svg"
                    alt="Check"
                  />
                  Improve user experience continuously
                </p>
              </div>

              <div class="flex flex-col sm:flex-row gap-2">
                <button
                  type="button"
                  class="primary w-full sm:w-auto"
                  onclick="window.location.href = '/login'"
                >
                  Start Now
                </button>
                <button
                  type="button"
                  class="ghost w-full sm:w-auto"
                  onclick="window.location.href = '/api/openapi.json'"
                >
                  View API Spec
                </button>
              </div>

              <p class="small muted">
                No complex setup. Create flags and ship.
              </p>
            </div>

            <div class="w-full max-w-lg panel-right">
              <!-- External SVG: quickstart illustration -->
              <img
                class="qs-illustration"
                src="/illustrations/quickstart.svg"
                alt="Quick start illustration"
              />
            </div>
          </div>
        </section>
      </div>
      <%- include('partials/footer') %>
    </div>
  </body>
</html>
