<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Feature Flags UI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/style.css" />
  </head>
  <body
    class="antialiased bg-gradient-to-br from-slate-900 via-slate-800 to-cyan-950"
  >
    <div class="root h-full">
      <%- include('partials/header') %>

      <div class="container mt-4 sm:mt-6 p-4">
        <!-- Hero -->

        <section class="mt-6">
          <div
            class="hero-juicy flex flex-col-reverse md:flex-row items-center justify-between gap-8 rounded-2xl p-6 md:p-12 shadow-2xl relative overflow-hidden"
            style="
              background: linear-gradient(
                120deg,
                rgba(8, 47, 73, 0.98) 0%,
                rgba(6, 182, 212, 0.13) 40%,
                rgba(96, 165, 250, 0.1) 70%,
                rgba(124, 58, 237, 0.09) 100%
              );
            "
          >
            <div class="flex-1 z-10 text-center md:text-left">
              <h1
                class="text-4xl md:text-5xl font-extrabold mb-4 bg-gradient-to-r from-cyan-400 via-blue-400 to-cyan-300 bg-clip-text text-transparent drop-shadow-lg"
              >
                Launch new ideas<br class="hidden md:inline" />
                <span class="whitespace-nowrap">without the stress.</span>
              </h1>
              <p
                class="text-lg md:text-xl text-slate-300 mb-6 max-w-lg mx-auto md:mx-0"
              >
                Release in smaller steps, stay in control, and adapt instantly.
              </p>
              <div
                class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start"
              >
                <a
                  href="/login"
                  class="bg-cyan-500/90 hover:bg-cyan-400 text-white px-6 py-3 rounded-lg font-semibold shadow-lg hover:shadow-xl transition transform hover:-translate-y-1 w-full sm:w-auto text-lg"
                >
                  Get Started
                </a>
                <a
                  href="/api-reference"
                  class="border border-cyan-400/30 text-cyan-100 px-6 py-3 rounded-lg hover:bg-cyan-400/10 transition w-full sm:w-auto text-lg"
                >
                  API Reference
                </a>
              </div>
            </div>
            <div class="flex-1 flex items-center justify-center relative z-10">
              <img
                class="hero-illustration drop-shadow-2xl max-w-full md:max-w-lg lg:max-w-xl animate-fade-in"
                src="/illustrations/hero.svg"
                alt="Feature rollout illustration"
                style="z-index: 2"
              />
            </div>
          </div>
        </section>

        <!-- Quick Start -->
        <section class="mt-10 mb-8">
          <div
            class="rounded-xl bg-slate-800/80 border border-cyan-700/30 shadow-lg p-6 md:p-10 w-full"
          >
            <h2
              class="text-2xl font-bold text-cyan-300 mb-3 flex items-center gap-2"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="inline w-7 h-7 text-cyan-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 16h-1v-4h-1m1-4h.01M12 20a8 8 0 100-16 8 8 0 000 16z"
                />
              </svg>
              Quick Start
            </h2>
            <ol class="list-decimal list-inside text-slate-200 space-y-2 mb-4">
              <li>
                <span class="font-semibold text-cyan-200">Clone the repo:</span>
                <pre
                  class="bg-slate-900 rounded p-2 mt-1 text-cyan-200 text-sm overflow-x-auto"
                >
git clone &lt;your-repo-url&gt;</pre
                >
              </li>
              <li>
                <span class="font-semibold text-cyan-200"
                  >Install dependencies:</span
                >
                <pre
                  class="bg-slate-900 rounded p-2 mt-1 text-cyan-200 text-sm overflow-x-auto"
                >
npm install</pre
                >
              </li>
              <li>
                <span class="font-semibold text-cyan-200"
                  >Start the app (auto-initializes DB):</span
                >
                <pre
                  class="bg-slate-900 rounded p-2 mt-1 text-cyan-200 text-sm overflow-x-auto"
                >
npm start</pre
                >
              </li>
              <li>
                <span class="font-semibold text-cyan-200"
                  >Create a migration placeholder:</span
                >
                <pre
                  class="bg-slate-900 rounded p-2 mt-1 text-cyan-200 text-sm overflow-x-auto"
                >
npm run migration:create -- add_feature_x</pre
                >
              </li>
            </ol>
            <div class="text-slate-400 text-sm">
              <span class="font-semibold text-cyan-200">Tip:</span> Edit the
              generated migration file in
              <span class="font-mono text-cyan-300">src/migrations/</span> and
              run <span class="font-mono text-cyan-300">npm start</span> to
              apply it automatically.
            </div>
          </div>
        </section>

        <!-- Features -->
        <section class="mt-6">
          <div class="mb-4">
            <h3 class="mb-1">Why people love using Easy Flags</h3>
            <p class="text-sm text-slate-400">
              Simple, clear, and built for fast teams.
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mt-6">
            <div
              class="flex-1 rounded-lg bg-white/5 p-4 flex items-center gap-3"
            >
              <div
                class="w-12 h-12 rounded-full flex items-center justify-center text-xl shadow-lg bg-cyan-200/20"
              >
                <img class="icon" src="/icons/rocket.svg" alt="Rocket" />
              </div>
              <div>
                <p class="text-sm font-semibold text-white">Faster releases</p>
                <p class="text-sm text-slate-400">Ship in smaller steps.</p>
              </div>
            </div>
            <div
              class="flex-1 rounded-lg bg-white/5 p-4 flex items-center gap-3"
            >
              <div
                class="w-12 h-12 rounded-full flex items-center justify-center text-xl shadow-lg bg-green-400/20"
              >
                <img class="icon" src="/icons/target.svg" alt="Target" />
              </div>
              <div>
                <p class="text-sm font-semibold text-white">More control</p>
                <p class="text-sm text-slate-400">Toggle anytime.</p>
              </div>
            </div>
            <div
              class="flex-1 rounded-lg bg-white/5 p-4 flex items-center gap-3"
            >
              <div
                class="w-12 h-12 rounded-full flex items-center justify-center text-xl shadow-lg bg-purple-500/20"
              >
                <img class="icon" src="/icons/heart.svg" alt="Heart" />
              </div>
              <div>
                <p class="text-sm font-semibold text-white">Better UX</p>
                <p class="text-sm text-slate-400">Improve what users feel.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Comparisons -->
        <section class="mt-6">
          <div class="mb-4">
            <h3 class="mb-1">Simple journeys, real impact</h3>
            <p class="text-sm text-slate-400">
              Each comparison shows how Easy Flags turns friction into faster,
              safer delivery.
            </p>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-16">
            <div
              class="rounded-lg bg-white/5 p-6 flex flex-col min-h-full mt-6"
            >
              <div class="flex items-center justify-between tile-header">
                <div class="flex items-center gap-3">
                  <div
                    class="w-12 h-12 rounded-full flex items-center justify-center text-xl bg-cyan-200/20 shadow-md"
                  >
                    <img class="icon" src="/icons/check.svg" alt="Check" />
                  </div>
                  <p class="text-sm font-semibold text-white">Launches</p>
                </div>
                <p class="text-sm text-slate-400">Before → After</p>
              </div>
              <div
                class="w-full flex items-center justify-center py-4"
                role="img"
                aria-label="Launches: time to release"
              >
                <img
                  class="max-w-full h-auto block"
                  src="/illustrations/compare-launches.svg"
                  alt="Launches before and after"
                />
              </div>
              <p class="text-sm text-slate-400 mt-3">
                Move from risky all-at-once launches to progressive rollouts
                with better control.
              </p>
            </div>

            <div
              class="rounded-lg bg-white/5 p-6 flex flex-col min-h-full mt-6"
            >
              <div class="flex items-center justify-between tile-header">
                <div class="flex items-center gap-3">
                  <div
                    class="w-12 h-12 rounded-full flex items-center justify-center text-xl bg-green-400/20 shadow-md"
                  >
                    <img
                      class="icon"
                      src="/icons/lifebuoy.svg"
                      alt="Lifebuoy"
                    />
                  </div>
                  <p class="text-sm font-semibold text-white">Reliability</p>
                </div>
                <p class="text-sm text-slate-400">Before → After</p>
              </div>
              <div
                class="w-full flex items-center justify-center py-4"
                role="img"
                aria-label="Reliability: incidents per month"
              >
                <img
                  class="max-w-full h-auto block"
                  src="/illustrations/compare-reliability.svg"
                  alt="Reliability before and after"
                />
              </div>
              <p class="text-sm text-slate-400 mt-3">
                Reduce downtime by switching unstable features off instantly
                instead of waiting for a redeploy.
              </p>
            </div>

            <div
              class="rounded-lg bg-white/5 p-6 flex flex-col min-h-full mt-6"
            >
              <div class="flex items-center justify-between tile-header">
                <div class="flex items-center gap-3">
                  <div
                    class="w-12 h-12 rounded-full flex items-center justify-center text-xl bg-purple-500/20 shadow-md"
                  >
                    <img
                      class="icon"
                      src="/icons/sparkles.svg"
                      alt="Sparkles"
                    />
                  </div>
                  <p class="text-sm font-semibold text-white">Product fit</p>
                </div>
                <p class="text-sm text-slate-400">Before → After</p>
              </div>
              <div
                class="w-full flex items-center justify-center py-4"
                role="img"
                aria-label="Product fit: % features validated"
              >
                <img
                  class="max-w-full h-auto block"
                  src="/illustrations/compare-productfit.svg"
                  alt="Product fit before and after"
                />
              </div>
              <p class="text-sm text-slate-400 mt-3">
                Replace guesswork with fast experiments and measurable learning
                across environments.
              </p>
            </div>

            <div
              class="rounded-lg bg-white/5 p-6 flex flex-col min-h-full mt-6"
            >
              <div class="flex items-center justify-between tile-header">
                <div class="flex items-center gap-3 justify-center">
                  <div
                    class="w-12 h-12 rounded-full flex items-center justify-center text-xl bg-cyan-200/20 shadow-md"
                  >
                    <img class="icon" src="/icons/bolt.svg" alt="Bolt" />
                  </div>
                  <p class="text-sm font-semibold text-white">
                    Deployment Frequency
                  </p>
                </div>
                <p class="text-sm text-slate-400">Before → After</p>
              </div>
              <div
                class="w-full flex items-center justify-center py-4"
                role="img"
                aria-label="Deployment frequency per week"
              >
                <img
                  class="max-w-full h-auto block"
                  src="/illustrations/compare-frequency.svg"
                  alt="Deployment frequency before and after"
                />
              </div>
              <p class="text-sm text-slate-400 mt-3">
                Deploy changes multiple times a day instead of waiting for
                weekly releases.
              </p>
            </div>
          </div>
        </section>

        <!-- CTA: focused -->
        <section class="mt-8">
          <div
            class="rounded-lg bg-white/4 p-6 flex flex-col md:flex-row items-center justify-between gap-4"
          >
            <div>
              <h4 class="text-lg font-semibold text-white">
                Ready to get started?
              </h4>
              <p class="text-sm text-slate-400">
                Create flags and ship faster with confidence.
              </p>
            </div>
            <div class="flex gap-3">
              <a
                href="/create-account"
                class="bg-cyan-500 text-white px-4 py-2 rounded-md shadow-sm inline-block"
              >
                Create account
              </a>
              <a
                href="/api-reference"
                class="text-sm text-slate-300 self-center underline"
                >API Reference</a
              >
            </div>
          </div>
        </section>
      </div>
      <%- include('partials/footer') %>
    </div>
  </body>
</html>
