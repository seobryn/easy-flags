<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact Us | Easy Flags</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/style.css" />
  </head>
  <body
    class="antialiased bg-gradient-to-br from-slate-900 via-slate-800 to-cyan-950"
  >
    <div class="root h-full">
      <%- include('partials/header') %>

      <div class="container mt-4 sm:mt-6 p-4">
        <section class="mt-6 mb-12">
          <div class="max-w-2xl mx-auto">
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
              Get in Touch
            </h1>
            <p class="text-lg text-slate-300 mb-8">
              Have a question or feedback? We'd love to hear from you. Send us a
              message and we'll respond as soon as possible.
            </p>

            <div
              class="bg-slate-800/40 border border-cyan-500/20 rounded-xl p-8 mb-8"
            >
              <form class="space-y-6">
                <div>
                  <label
                    for="name"
                    class="block text-sm font-semibold text-cyan-300 mb-2"
                  >
                    Name
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 rounded-lg bg-slate-700/50 border border-cyan-500/20 text-white placeholder-slate-400 focus:border-cyan-400 focus:outline-none transition"
                    placeholder="Your name"
                  />
                </div>

                <div>
                  <label
                    for="email"
                    class="block text-sm font-semibold text-cyan-300 mb-2"
                  >
                    Email
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 rounded-lg bg-slate-700/50 border border-cyan-500/20 text-white placeholder-slate-400 focus:border-cyan-400 focus:outline-none transition"
                    placeholder="your@email.com"
                  />
                </div>

                <div>
                  <label
                    for="subject"
                    class="block text-sm font-semibold text-cyan-300 mb-2"
                  >
                    Subject
                  </label>
                  <input
                    type="text"
                    id="subject"
                    name="subject"
                    required
                    class="w-full px-4 py-3 rounded-lg bg-slate-700/50 border border-cyan-500/20 text-white placeholder-slate-400 focus:border-cyan-400 focus:outline-none transition"
                    placeholder="How can we help?"
                  />
                </div>

                <div>
                  <label
                    for="message"
                    class="block text-sm font-semibold text-cyan-300 mb-2"
                  >
                    Message
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    rows="5"
                    required
                    class="w-full px-4 py-3 rounded-lg bg-slate-700/50 border border-cyan-500/20 text-white placeholder-slate-400 focus:border-cyan-400 focus:outline-none transition resize-none"
                    placeholder="Tell us more about your inquiry..."
                  ></textarea>
                </div>

                <button
                  type="submit"
                  class="w-full bg-cyan-500/90 hover:bg-cyan-400 text-white font-semibold py-3 rounded-lg transition transform hover:scale-105 shadow-lg hover:shadow-xl"
                >
                  Send Message
                </button>
              </form>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div class="text-center">
                <div class="text-4xl mb-3">📧</div>
                <h3 class="text-lg font-semibold text-white mb-2">Email</h3>
                <p class="text-slate-400">
                  <a
                    href="mailto:support@easyflags.io"
                    class="text-cyan-400 hover:text-cyan-300"
                  >
                    support@easyflags.io
                  </a>
                </p>
              </div>

              <div class="text-center">
                <div class="text-4xl mb-3">💬</div>
                <h3 class="text-lg font-semibold text-white mb-2">Chat</h3>
                <p class="text-slate-400">
                  Join our community Slack for real-time support
                </p>
              </div>

              <div class="text-center">
                <div class="text-4xl mb-3">🚀</div>
                <h3 class="text-lg font-semibold text-white mb-2">Discord</h3>
                <p class="text-slate-400">
                  Connect with other developers in our community
                </p>
              </div>
            </div>
          </div>
        </section>
      </div>

      <%- include('partials/footer') %>
    </div>
  </body>
</html>
