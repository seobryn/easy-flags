<% 
const endpoints = [
  {
    method: 'POST',
    path: '/auth/login',
    summary: 'Login',
    description: 'Authenticate and receive a JWT token for subsequent requests.'
  },
  {
    method: 'GET',
    path: '/environments',
    summary: 'List environments',
    description: 'Retrieve all environments.'
  },
  {
    method: 'POST',
    path: '/environments',
    summary: 'Create environment',
    description: 'Create a new environment.'
  },
  {
    method: 'GET',
    path: '/features',
    summary: 'List features',
    description: 'Retrieve all features.'
  },
  {
    method: 'POST',
    path: '/features',
    summary: 'Create feature',
    description: 'Create a new feature flag.'
  },
  {
    method: 'PUT',
    path: '/features/{id}/value',
    summary: 'Set feature value for environment',
    description: 'Set a feature\'s value (enabled/disabled) for a specific environment.'
  },
  {
    method: 'GET',
    path: '/flags',
    summary: 'Get flags for environment',
    description: 'Get all feature flags for a specific environment.'
  },
  {
    method: 'GET',
    path: '/flags/{env}/{key}',
    summary: 'Check if a feature is enabled for an environment',
    description: 'Check if a specific feature is enabled in an environment.'
  }
];
%>
<div class="page space-y-8">
  <section class="bg-slate-900 rounded-2xl p-10 shadow-2xl border border-cyan-700/30">
    <h1 class="text-4xl font-extrabold text-cyan-300 mb-4 drop-shadow-lg tracking-tight">API Reference</h1>
    <p class="text-lg text-slate-200 mb-6">A complete guide to using the <span class="font-mono text-cyan-400">Feature Flags API</span>. All endpoints are under <span class="font-mono text-cyan-300">/api</span>.</p>
    <div class="mb-10">
      <h2 class="text-2xl font-bold text-cyan-400 mb-3">Authentication</h2>
      <p class="text-slate-300 mb-3">Authenticate via JWT. Obtain a token by logging in:</p>
      <div class="bg-slate-800 rounded-xl p-5 border border-cyan-700/40 shadow-lg">
        <pre><code class="language-bash">curl -X POST http://localhost:3000/api/auth/login \
  -H "Content-Type: application/json" \
  -d '{"username":"admin","password":"password"}'</code></pre>
      </div>
      <p class="text-slate-400 mt-3">Use the token in the <span class="font-mono">Authorization: Bearer &lt;token&gt;</span> header for all requests.</p>
    </div>
    <div class="mb-10">
      <h2 class="text-2xl font-bold text-cyan-400 mb-3">Endpoints</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <% endpoints.forEach(ep => { %>
        <div class="endpoint-card bg-slate-800 rounded-xl p-6 border border-cyan-700/30 shadow-lg flex flex-col gap-2">
          <div class="flex items-center gap-2 mb-1">
            <% if (ep.method === 'GET') { %>
              <span class="inline-block px-3 py-1 rounded-full bg-blue-500 text-white text-xs font-bold">GET</span>
            <% } else if (ep.method === 'POST') { %>
              <span class="inline-block px-3 py-1 rounded-full bg-green-500 text-white text-xs font-bold">POST</span>
            <% } else if (ep.method === 'PUT') { %>
              <span class="inline-block px-3 py-1 rounded-full bg-amber-400 text-white text-xs font-bold">PUT</span>
            <% } else if (ep.method === 'DELETE') { %>
              <span class="inline-block px-3 py-1 rounded-full bg-red-500 text-white text-xs font-bold">DELETE</span>
            <% } else if (ep.method === 'PATCH') { %>
              <span class="inline-block px-3 py-1 rounded-full bg-green-300 text-white text-xs font-bold">PATCH</span>
            <% } else if (ep.method === 'OPTIONS') { %>
              <span class="inline-block px-3 py-1 rounded-full bg-blue-gray-500 text-white text-xs font-bold">OPTIONS</span>
            <% } else if (ep.method === 'HEAD') { %>
              <span class="inline-block px-3 py-1 rounded-full bg-purple-500 text-white text-xs font-bold">HEAD</span>
            <% } %>
            <span class="font-mono text-cyan-300 text-base"><%= ep.path %></span>
          </div>
          <span class="text-cyan-200 text-base font-semibold"><%= ep.summary %></span>
          <span class="text-slate-300 text-sm"><%= ep.description %></span>
        </div>
        <% }) %>
      </div>
    </div>
    <div class="mb-10">
      <h2 class="text-2xl font-bold text-cyan-400 mb-3">Usage Examples</h2>
      
      <h3 class="text-xl font-semibold text-white mb-3 mt-6">Using EasyFlags JavaScript Library (Recommended)</h3>
      <p class="text-slate-300 mb-3">The easiest way to interact with the Feature Flags API is using the <span class="font-mono text-cyan-400">EasyFlags</span> library. It handles authentication, errors, and provides a clean API.</p>
      <div class="bg-slate-800 rounded-xl p-5 border border-cyan-700/40 shadow-lg">
        <pre><code class="language-js">// Instantiate EasyFlags before use
const easyFlags = new EasyFlags();

// Get all features
const features = await easyFlags.listFeatures();
console.log('Features:', features);

// Get all flags for an environment
const { environment, flags } = await easyFlags.getFlags('production');
flags.forEach(flag => {
  console.log(`${flag.key}: ${flag.value}`);
});

// Check if a specific feature is enabled
const isEnabled = await easyFlags.getFlag('production', 'new-dashboard');
if (isEnabled) {
  // Show new feature
} else {
  // Show old feature
}

// Create a new feature
const feature = await easyFlags.createFeature('beta-ui', 'New UI v2');
console.log('Created:', feature);

// Set a feature value for an environment
await easyFlags.setFeatureValue(feature.id, 1, true); // Enable in dev
await easyFlags.setFeatureValue(feature.id, 2, false); // Disable in staging
</code></pre>
      </div>
      <p class="text-slate-400 mt-3 text-sm">
        <strong>Benefits:</strong> No manual fetch calls, automatic error handling, built-in authentication, type hints with JSDoc.
        <br/>
        <strong>Setup:</strong> The library is included in the page layout automatically. <br/>
        <strong>Note:</strong> You must instantiate <span class="font-mono text-cyan-400">EasyFlags</span> before use.
      </p>

      <h3 class="text-xl font-semibold text-white mb-3 mt-6">JavaScript/Node.js (Manual Fetch)</h3>
      <div class="bg-slate-800 rounded-xl p-5 border border-cyan-700/40 shadow-lg">
        <pre><code class="language-js">// Login and get token
const loginRes = await fetch('/api/auth/login', {
  method: 'POST',
  headers: { 'Content-Type': 'application/json' },
  body: JSON.stringify({
    username: 'your_username',
    password: 'your_password'
  })
});

const { token } = await loginRes.json();
const headers = {
  'Authorization': `Bearer ${token}`,
  'Content-Type': 'application/json'
};

// Check if a feature is enabled
const flagRes = await fetch('/api/flags/production/new_dashboard', {
  headers
});
const { enabled } = await flagRes.json();

if (enabled) {
  // Show new feature
} else {
  // Show old feature
}
</code></pre>
      </div>
      <h3 class="text-xl font-semibold text-white mb-3 mt-6">cURL</h3>
      <div class="bg-slate-800 rounded-xl p-5 border border-cyan-700/40 shadow-lg">
        <pre><code class="language-bash"># Login
curl -X POST http://localhost:3000/api/auth/login \
  -H "Content-Type: application/json" \
  -d '{"username":"admin","password":"password"}'

# Get all flags for production
curl http://localhost:3000/api/flags?env=production \
  -H "Authorization: Bearer YOUR_TOKEN"

# Check specific flag
curl http://localhost:3000/api/flags/production/new_dashboard \
  -H "Authorization: Bearer YOUR_TOKEN"
</code></pre>
      </div>
    </div>
    <div class="mb-6">
      <h2 class="text-2xl font-bold text-cyan-400 mb-3">Error Handling</h2>
      <ul class="text-slate-200 text-base space-y-2 pl-4">
        <li><span class="font-mono text-cyan-300">200 OK</span> – Request succeeded</li>
        <li><span class="font-mono text-cyan-300">201 Created</span> – Resource created successfully</li>
        <li><span class="font-mono text-cyan-300">400 Bad Request</span> – Invalid request parameters</li>
        <li><span class="font-mono text-cyan-300">401 Unauthorized</span> – Missing or invalid authentication</li>
        <li><span class="font-mono text-cyan-300">404 Not Found</span> – Resource not found</li>
        <li><span class="font-mono text-cyan-300">500 Server Error</span> – Internal server error</li>
      </ul>
    </div>
  </section>
</div>