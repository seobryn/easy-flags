<div class="page space-y-4">
  <section class="bg-white/5 rounded-lg p-6">
    <div
      class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4"
    >
      <h3>Roles Management</h3>
      <button
        id="openCreateRole"
        class="bg-cyan-500 text-white px-4 py-2 rounded-md w-full sm:w-auto"
        type="button"
      >
        Create Role
      </button>
    </div>
  </section>

  <section class="bg-white/5 rounded-lg p-6">
    <h3 class="mb-4">Existing Roles</h3>
    <div class="overflow-x-auto">
      <table
        id="rolesTable"
        class="min-w-full table-auto divide-y divide-white/6"
      >
        <thead>
          <tr>
            <th class="text-left p-3 sm:p-4">Name</th>
            <th class="text-left p-3 sm:p-4">Description</th>
            <th class="text-center p-3 sm:p-4 w-64 sm:w-80">Actions</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </section>
</div>

<!-- Create/Edit Role Modal -->
<div
  id="roleModal"
  class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4"
>
  <div class="bg-slate-900 rounded-lg p-6 max-w-md w-full">
    <h3 id="roleModalTitle" class="mb-4 text-lg font-semibold">Create Role</h3>
    <form id="roleForm" class="space-y-4">
      <input type="hidden" id="roleId" />
      <div>
        <label for="roleName" class="block text-sm font-medium mb-1"
          >Role Name</label
        >
        <input
          id="roleName"
          type="text"
          placeholder="e.g., Manager"
          class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder:text-white/50"
          required
        />
      </div>
      <div>
        <label for="roleDescription" class="block text-sm font-medium mb-1"
          >Description</label
        >
        <textarea
          id="roleDescription"
          placeholder="Role description..."
          class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder:text-white/50"
          rows="3"
        ></textarea>
      </div>
      <div class="flex gap-2 justify-end">
        <button
          type="button"
          id="closeRoleModal"
          class="bg-gray-600 text-white px-4 py-2 rounded"
        >
          Cancel
        </button>
        <button type="submit" class="bg-cyan-500 text-white px-4 py-2 rounded">
          Save Role
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Manage Permissions Modal -->
<div
  id="permissionsModal"
  class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4"
>
  <div
    class="bg-slate-900 rounded-lg shadow-lg w-full max-w-md flex flex-col max-h-[80vh]"
  >
    <!-- Modal Header with Close Button -->
    <div class="flex items-center justify-between p-6 border-b border-white/10">
      <h3 class="text-lg font-bold text-white">
        Manage Permissions for <span id="permissionRoleName"></span>
      </h3>
      <button
        type="button"
        onclick="handleClosePermissionsModal()"
        class="text-white/60 hover:text-white transition-colors p-1"
        aria-label="Close modal"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M18 6L6 18M6 6l12 12"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </button>
    </div>
    <!-- Permissions Container -->
    <div id="permissionsContainer" class="space-y-3 flex-1 overflow-y-auto p-6">
      <!-- Permissions will be rendered here by JS, with URL mapping -->
    </div>
  </div>
</div>

<script src="/js/roles.js"></script>
