PORT=3000

# Local SQLite Database (development)
DATABASE_URL=file:./data.db

# Turso Remote Database (production)
# DATABASE_URL=libsql://your-db-name-your-org.turso.io
# DATABASE_AUTH_TOKEN=eyJhbGciOiJFZENTU0EiLCJ0eXAiOiJKV1QifQ...

JWT_SECRET=change-me
ADMIN_USER=admin
ADMIN_PASS=password

# Mercadopago Configuration
# Get these from your Mercadopago account at https://www.mercadopago.com.co/developers
PUBLIC_MERCADOPAGO_PUBLIC_KEY=YOUR_PUBLIC_KEY
MERCADOPAGO_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
MERCADOPAGO_WEBHOOK_URL=https://your-domain.com/api/mercadopago/webhook
MERCADOPAGO_WEBHOOK_SECRET=your_webhook_secret_here
