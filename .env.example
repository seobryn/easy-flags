# Easy Flags - Environment Variables Template
# Copy this file to .env and fill in the values

# ===========================================
# REQUIRED - Application
# ===========================================

# JWT Secret for signing auth tokens (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Site URL (used for email links, OG tags, etc.)
SITE_URL=https://easy-flags.orangeember.com

# Admin credentials (change in production!)
ADMIN_USER=admin
ADMIN_PASS=changeme

# ===========================================
# REQUIRED - Database (LibSQL)
# ===========================================

# Connection URL for LibSQL
# Local file: file:./data.db
# Turso: libsql://your-database.turso.io
DATABASE_URL=file:./data.db

# Auth token for Turso (if using Turso cloud)
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# ===========================================
# REQUIRED - Payment Processing (WOMPI)
# ===========================================

# Get these from your WOMPI dashboard
WOMPI_PUBLIC_KEY=pub_test_your-public-key
WOMPI_PRIVATE_KEY=pri_your-private-key
WOMPI_INTEGRITY_SECRET=your-integrity-secret
WOMPI_EVENT_SECRET=your-webhook-event-secret

# ===========================================
# OPTIONAL - Email (Resend)
# ===========================================

# Get your API key from https://resend.com
# RESEND_API_KEY=re_1234567890

# Email sender address
# EMAIL_FROM=onboarding@resend.dev

# ===========================================
# OPTIONAL - Error Tracking (Sentry)
# ===========================================

# Get from Sentry project settings
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ===========================================
# OPTIONAL - Rate Limiting (Upstash Redis)
# ===========================================

# For production rate limiting with Redis
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ===========================================
# DEVELOPMENT OPTIONS
# ===========================================

# Set to "production" for production builds
NODE_ENV=development